{% comment %}
  Snippet: collection-tabs-card.liquid  v3
  Place in: snippets/collection-tabs-card.liquid

  Parameters passed from section:
    product        — Shopify product object
    show_stars     — boolean  (from block setting)
    star_count     — integer 1–5 (from block setting, static)
    star_value     — string '5.0' etc (from block setting, static)
    show_badge     — boolean (from section setting)
    badge_type     — 'auto' | 'custom'
    badge_text     — string
    card_style     — 'standard' | 'card'
    show_cart_btn  — boolean
    cart_btn_style — 'icon' | 'text' | 'text_only'
    cart_icon_svg  — html string (optional)
{% endcomment %}

{%- liquid
  assign cp = product
  assign has_image = false
  if product.featured_image
    assign has_image = true
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign discount_pct = 0
  if on_sale and product.compare_at_price > 0
    assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
  endif

  if compare > current
    assign is_on_sale = true
    assign diff = compare | minus: current
    assign discount_pct = diff | times: 100 | divided_by: compare | round
  endif

  assign s_count = star_count | default: 5
  assign s_val = star_value | default: '5.0'
  assign s_empty = 5 | minus: s_count
-%}
<div class="collection-tabs__card{% if card_style == 'card' %} collection-tabs__card--elevated{% endif %}">
  <a href="{{ product.url }}" class="collection-tabs__card-link" aria-label="{{ product.title | escape }}">
    <div class="collection-tabs__card-image-wrap">

      {%- comment %} Badge {%- endcomment %}
      {%- if show_badge and on_sale -%}
        <div class="collection-tabs__badge" aria-label="On sale">
          {%- if badge_type == 'auto' -%}
            {{ discount_pct }}% OFF
          {%- else -%}
            {{ badge_text }}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment %} Product image or placeholder {%- endcomment %}
      {%- if has_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
          width="600"
          height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
          loading="lazy"
          class="collection-tabs__card-img"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg collection-tabs__placeholder-img' }}
      {%- endif -%}

      {%- comment %} Cart button {%- endcomment %}
      {%- if show_cart_btn -%}
        <button
          class="ct-cart-btn ct-cart-btn--corner"
          aria-label="Add {{ product.title | escape }} to cart"
          data-product-id="{{ product.variants.first.id }}"
        >
          {%- if cart_icon_svg != blank -%}
            {{ cart_icon_svg }}
          {%- elsif cart_btn_style != 'text_only' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          {%- endif -%}
          {%- if cart_btn_style == 'text' or cart_btn_style == 'text_only' -%}
            <span>Add to Cart</span>
          {%- endif -%}
        </button>
      {%- endif -%}

    </div>
  </a>

  <div class="collection-tabs__card-info">
    {%- if show_stars -%}
      <div class="collection-tabs__card-stars" aria-label="Rated {{ star_value }} out of 5">
        {%- for i in (1..star_count) -%}★{%- endfor -%}
        {%- assign empty_stars = 5 | minus: star_count -%}
        {%- for i in (1..empty_stars) -%}<span class="ct-star-empty">★</span>{%- endfor -%}
        <span>{{ star_value }}</span>
      </div>
    {%- endif -%}

    <h3 class="collection-tabs__card-title">{{ product.title | truncate : 25 }}</h3>

    <p class="collection-tabs__card-price">
      {%- if on_sale -%}
        {% comment %} <s class="ct-price-compare">{{ product.compare_at_price | money }}</s> {% endcomment %}
        <span class="ct-price-sale">{{ product.price | money }}</span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </p>
  </div>
</div>


{%- comment %} Cart AJAX — injected only once per page ── {%- endcomment %}
{%- unless ct_cart_js_done -%}
  {%- assign ct_cart_js_done = true -%}
  <script>
    if (typeof ctAddToCart === 'undefined') {
      window.ctAddToCart = function (btn) {
        var id = btn.dataset.productId;
        if (!id) return;
        btn.disabled = true;
        btn.classList.add('ct-cart-btn--loading');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(id), quantity: 1 }),
        })
          .then(function (r) {
            return r.json();
          })
          .then(function () {
            btn.classList.remove('ct-cart-btn--loading');
            btn.classList.add('ct-cart-btn--added');
            /* Notify theme cart drawer */
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            var cartCount = document.querySelectorAll('.cart-count-bubble, .cart__count, [data-cart-count]');
            fetch('/cart.js')
              .then(function (r) {
                return r.json();
              })
              .then(function (cart) {
                cartCount.forEach(function (el) {
                  el.textContent = cart.item_count;
                });
              });
            setTimeout(function () {
              btn.classList.remove('ct-cart-btn--added');
              btn.disabled = false;
            }, 1600);
          })
          .catch(function () {
            btn.disabled = false;
            btn.classList.remove('ct-cart-btn--loading');
          });
      };
    }
  </script>
{%- endunless -%}
