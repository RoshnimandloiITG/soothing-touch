
{% comment %}
  <section
    id="trending-gate-{{ section.id }}"
    class="trending-gate-section color-{{  }} gradient"
    style="
      --heading-size: {{ section.settings.heading_size }}px;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >

  <div class="trending-container">

    <div class="trending-layout">

      <!-- LEFT WORD -->
      <div class="gate-word gate-left">
        {{ section.settings.heading | split: ' ' | first }}
      </div>

      <!-- COLLECTIONS -->
      <div class="collections-row">

        {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}

        {% if collection != blank %}
        <a
          href="{{ collection.url }}"
          class="collection-card"
          {{ block.shopify_attributes }}
        >

          <div class="card-image">

            {% if block.settings.custom_image %}
              <img
                src="{{ block.settings.custom_image | image_url: width: 400 }}"
                alt="{{ collection.title }}"
                loading="lazy"
              >
            {% elsif collection.image %}
              <img
                src="{{ collection.image | image_url: width: 400 }}"
                alt="{{ collection.title }}"
                loading="lazy"
              >
            {% endif %}

          </div>

          <div class="card-title">
            {% if block.settings.custom_title != blank %}
              {{ block.settings.custom_title }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </div>

        </a>
        {% endif %}
        {% endfor %}

      </div>

      <!-- RIGHT WORD -->
      <div class="gate-word gate-right">
        {{ section.settings.heading | split: ' ' | last }}
      </div>

    </div>

  </div>

  <style>

  /* SECTION */

  #trending-gate-{{ section.id }}{
    overflow:hidden;
  }

  /* CONTAINER */

  #trending-gate-{{ section.id }} .trending-container{
    max-width:1400px;
    margin:auto;
  }

  /* LAYOUT */

  #trending-gate-{{ section.id }} .trending-layout{

    display:flex;
    align-items:center;
    justify-content:center;
    gap:12px;
    width:100%;
    text-align:center;

  }

  /* WORDS */

  #trending-gate-{{ section.id }} .gate-word{
    font-size:var(--heading-size);
    font-weight:700;
    white-space:nowrap;
     /*  transition: transform 1.2s cubic-bezier(.22,.61,.36,1); */
        transition: transform 1.4s cubic-bezier(.22,.61,.36,1);
    will-change: transform;
    font-size:120px;

  }

  /* COLLECTION ROW

  #trending-gate-{{ section.id }} .collections-row{

    display:none;

    align-items:center;
    justify-content:center;

    gap:14px;

  }*/
  #trending-gate-{{ section.id }} .collections-row{

    display:flex; /* IMPORTANT change */

    align-items:center;
    justify-content:center;

    gap:14px;

    opacity:0;
    transform:translateY(20px);

    transition:
      opacity .6s cubic-bezier(.22,.61,.36,1),
      transform .6s cubic-bezier(.22,.61,.36,1);

  }

  /* CARD */

  #trending-gate-{{ section.id }} .collection-card{
    width:130px;
    border-radius:14px;
    text-decoration:none;
    color:inherit;
  }

  /* IMAGE */

  #trending-gate-{{ section.id }} .card-image{
    width:100%;
  height:100%;
  }

  #trending-gate-{{ section.id }} .card-image img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      max-width: 120px;
      height: 120px;
      border-radius: 15px;
  }


  /* TITLE */

  #trending-gate-{{ section.id }} .card-title{
    font-size:13px;
    font-weight:500;
  }

  /* ACTIVE STATE */

  #trending-gate-{{ section.id }}.active .gate-left{
    transform:translateX(-110px);
  }

  #trending-gate-{{ section.id }}.active .gate-right{
    transform:translateX(110px);
  }

  /* MOBILE */

  @media(max-width:768px){

  #trending-gate-{{ section.id }} .trending-layout{
    flex-direction:column;
  }

  #trending-gate-{{ section.id }} .gate-word{
    transform:none !important;
  }

  }

  </style>


  <script>
    document.addEventListener("DOMContentLoaded", function () {

    const section = document.querySelector("#trending-gate-{{ section.id }}");
    const collections = section.querySelector(".collections-row");

    if (!section) return;

    {% if section.settings.enable_animation %}

    let ticking = false;

    function updateAnimation() {

      const rect = section.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      let progress = (windowHeight - rect.top) / (windowHeight + rect.height);
      progress = Math.min(Math.max(progress, 0), 1);

      // 👉 EASING (magic here)
      const eased = progress * progress * (3 - 2 * progress);

      const move = eased * 140;

      section.querySelector(".gate-left").style.transform =
        `translateX(-${move}px)`;

      section.querySelector(".gate-right").style.transform =
        `translateX(${move}px)`;

      // 👉 smooth fade instead of display none
      if (progress > 0.35) {
        collections.style.opacity = 1;
        collections.style.transform = "translateY(0px)";
        collections.style.pointerEvents = "auto";
      } else {
        collections.style.opacity = 0;
        collections.style.transform = "translateY(20px)";
        collections.style.pointerEvents = "none";
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateAnimation);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll);
    window.addEventListener("resize", updateAnimation);

    updateAnimation();

    {% endif %}
  });
  </script>



  {% schema %}
  {
    "name": "Collection Split",
    "settings": [
  {
    "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
  },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Trending Products"
      },
      {
        "type": "range",
        "id": "heading_size",
        "label": "Heading Size",
        "min": 40,
        "max": 120,
        "step": 2,
        "default": 80
      },

      {
        "type": "color",
        "id": "heading_color",
        "label": "Heading Color",
        "default": "#8c6b4f"
      },

      {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color",
        "default": "#efe7e1"
      },

      {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 0,
        "max": 200,
        "step": 4,
        "default": 80
      },

      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "default": 80
      },

      {
        "type": "checkbox",
        "id": "enable_animation",
        "label": "Enable Animation",
        "default": true
      }

    ],
    "blocks": [

      {
        "type": "collection_card",
        "name": "Collection Card",
        "settings": [

          {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
          },

          {
            "type": "image_picker",
            "id": "custom_image",
            "label": "Custom Image"
          },

          {
            "type": "text",
            "id": "custom_title",
            "label": "Custom Title"
          }

        ]
      }

    ],
    "max_blocks": 7,
    "presets": [
      {
        "name": "Collection Split"
      }
    ],
  }
  {% endschema %}
{% endcomment %}
