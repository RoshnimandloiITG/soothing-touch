{% comment %}
  ╔══════════════════════════════════════════════════════════════════╗
  ║  Contact Page — Fully Dynamic Shopify Section                    ║
  ║  ─────────────────────────────────────────────────────────────  ║
  ║  Blocks available:                                               ║
  ║   • hero          — Full-width banner (icon, heading, image)     ║
  ║   • send_message  — Left card: logo, title, desc, CTA button     ║
  ║   • contact_info  — Right card: address + phone rows             ║
  ║   • wholesale     — Right card: icon, heading, desc, link        ║
  ║   • support_hours — Right card: hours table + note box           ║
  ║   • help_strip    — Bottom 3-col icon + label + desc strip       ║
  ║                                                                  ║
  ║  All blocks are optional — hidden if empty, placeholder in       ║
  ║  editor, fully responsive.                                       ║
  ╚══════════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign accent     = section.settings.accent_color
  assign page_bg    = section.settings.page_bg_color
  assign card_bg    = section.settings.card_bg_color
  assign text_main  = section.settings.text_main_color
  assign text_muted = section.settings.text_muted_color
  assign btn_bg     = section.settings.btn_bg_color
  assign btn_text   = section.settings.btn_text_color

  assign has_hero         = false
  assign has_send         = false
  assign has_right_blocks = false
  assign has_help_strip   = false

  for block in section.blocks
    case block.type
      when 'hero'
        assign has_hero = true
      when 'send_message'
        assign has_send = true
      when 'contact_info'
        assign has_right_blocks = true
      when 'wholesale'
        assign has_right_blocks = true
      when 'support_hours'
        assign has_right_blocks = true
      when 'help_strip'
        assign has_help_strip = true
    endcase
  endfor
-%}

<style>
  #cp-{{ section.id }} {
    --cp-accent:      {{ accent }};
    --cp-page-bg:     {{ page_bg }};
    --cp-card-bg:     {{ card_bg }};
    --cp-text:        {{ text_main }};
    --cp-muted:       {{ text_muted }};
    --cp-btn-bg:      {{ btn_bg }};
    --cp-btn-text:    {{ btn_text }};
    --cp-border:      rgba(0,0,0,0.08);
    --cp-icon-size:   22px;
  }

  /* ══════════════════════════════════
     BASE
  ══════════════════════════════════ */
  #cp-{{ section.id }} {
    background: var(--cp-page-bg);
    color: var(--cp-text);
    font-family: inherit;
  }

  /* ══════════════════════════════════
     HERO BANNER
  ══════════════════════════════════ */
  .cp-hero {
    position: relative;
    width: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .cp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .cp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.28) 0%, rgba(0,0,0,0.48) 100%);
    z-index: 1;
  }
  .cp-hero__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #c97b5a 0%, #8b4a3a 100%);
  }
  .cp-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .cp-hero__icon {
    width: 56px; height: 56px;
    color: #fff;
    opacity: 0.95;
  }
  .cp-hero__icon img {
    width: 100%; height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .cp-hero__icon svg {
    width: 100%; height: 100%;
  }
  .cp-hero__heading {
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 800;
    color: #fff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .cp-hero__sub {
    font-size: clamp(14px, 1.8vw, 18px);
    color: rgba(255,255,255,0.88);
    margin: 0;
    line-height: 1.5;
    max-width: 480px;
  }

  /* ══════════════════════════════════
     TWO-COL LAYOUT
  ══════════════════════════════════ */
  .cp-body {
    max-width: 1240px;
    margin: 0 auto;
    padding: 48px 24px 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: start;
  }
  .cp-left, .cp-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ══════════════════════════════════
     CARD BASE
  ══════════════════════════════════ */
  .cp-card {
    background: var(--cp-card-bg);
    border-radius: 18px;
    border: 1px solid var(--cp-border);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
  }
  .cp-card__inner {
    padding: 28px 28px 32px;
  }

  /* Card section heading */
  .cp-card__heading {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cp-accent);
    margin: 0 0 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cp-card__heading svg {
    width: 20px; height: 20px;
    flex-shrink: 0;
    color: var(--cp-accent);
  }

  /* ══════════════════════════════════
     SEND MESSAGE CARD (left)
  ══════════════════════════════════ */
  .cp-send {
    background: var(--cp-card-bg);
    border-radius: 18px;
    border: 1px solid var(--cp-border);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
  }
  .cp-send__inner {
    padding: 28px 28px 0;
  }
  .cp-send__heading {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cp-accent);
    margin: 0 0 22px;
  }

  /* Logo + title area */
  .cp-send__preview {
    background: #f5ede8;
    border-radius: 12px;
    padding: 40px 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    margin-bottom: 0;
  }
  .cp-send__logo img {
    max-width: 220px;
    width: 100%;
    height: auto;
    display: block;
  }
  .cp-send__logo-text {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: var(--cp-accent);
    letter-spacing: -0.02em;
    font-family: serif;
    line-height: 1;
  }
  .cp-send__title {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 700;
    color: var(--cp-accent);
    margin: 0;
    line-height: 1.3;
  }
  .cp-send__desc {
    font-size: 14px;
    color: var(--cp-muted);
    margin: 0;
    line-height: 1.55;
    max-width: 340px;
  }

  /* START button */
  .cp-send__btn-wrap {
    padding: 0;
  }
  .cp-send__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 18px 24px;
    background: var(--cp-btn-bg);
    color: var(--cp-btn-text);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    border-radius: 0 0 18px 18px;
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .cp-send__btn:hover {
    opacity: 0.9;
    filter: brightness(1.08);
  }
  .cp-send__btn svg {
    width: 18px; height: 18px;
    flex-shrink: 0;
  }

  /* ══════════════════════════════════
     CONTACT INFO CARD
  ══════════════════════════════════ */
  .cp-info-rows {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .cp-info-row {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .cp-info-row__icon {
    width: 22px; height: 22px;
    flex-shrink: 0;
    color: var(--cp-accent);
    margin-top: 1px;
  }
  .cp-info-row__body {}
  .cp-info-row__label {
    font-size: 14px;
    font-weight: 700;
    color: var(--cp-text);
    margin: 0 0 5px;
  }
  .cp-info-row__content {
    font-size: 14px;
    color: var(--cp-muted);
    line-height: 1.65;
    margin: 0;
    white-space: pre-line;
  }
  .cp-info-row__content a {
    color: var(--cp-muted);
    text-decoration: none;
    transition: color 0.18s;
  }
  .cp-info-row__content a:hover { color: var(--cp-accent); }
  .cp-info-row__note {
    font-size: 13px;
    color: var(--cp-muted);
    margin: 8px 0 0;
    font-style: italic;
  }

  /* ══════════════════════════════════
     WHOLESALE CARD
  ══════════════════════════════════ */
  .cp-wholesale__desc {
    font-size: 14px;
    color: var(--cp-muted);
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .cp-wholesale__link {
    font-size: 14px;
    font-weight: 600;
    color: var(--cp-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(0,0,0,0.3);
    transition: color 0.18s;
  }
  .cp-wholesale__link:hover { color: var(--cp-accent); }

  /* ══════════════════════════════════
     SUPPORT HOURS CARD
  ══════════════════════════════════ */
  .cp-hours-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }
  .cp-hours-table tr {
    border-bottom: 1px solid var(--cp-border);
  }
  .cp-hours-table tr:last-child { border-bottom: none; }
  .cp-hours-table td {
    padding: 10px 0;
    font-size: 14px;
    line-height: 1.4;
    color: var(--cp-text);
  }
  .cp-hours-table td:first-child { font-weight: 600; }
  .cp-hours-table td:last-child {
    text-align: right;
    color: var(--cp-muted);
  }
  .cp-hours-note {
    background: #f5f5f5;
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    color: var(--cp-muted);
    line-height: 1.55;
    margin: 0;
    border: 1px solid var(--cp-border);
  }

  /* ══════════════════════════════════
     HELP STRIP (bottom)
  ══════════════════════════════════ */
  .cp-help {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 24px 72px;
  }
  .cp-help__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .cp-help__heading {
    font-size: clamp(22px, 3.5vw, 36px);
    font-weight: 800;
    color: var(--cp-accent);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
  }
  .cp-help__sub {
    font-size: clamp(13px, 1.5vw, 15px);
    color: var(--cp-muted);
    margin: 0;
    line-height: 1.5;
  }

  .cp-help__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--cp-border);
    border-radius: 16px;
    overflow: hidden;
  }
  .cp-help__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 36px 24px;
    gap: 12px;
    border-right: 1px solid var(--cp-border);
  }
  .cp-help__col:last-child { border-right: none; }

  .cp-help__icon {
    width: 44px; height: 44px;
    color: var(--cp-accent);
  }
  .cp-help__icon svg { width: 100%; height: 100%; }
  .cp-help__col-label {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cp-accent);
    margin: 0;
  }
  .cp-help__col-desc {
    font-size: 13px;
    color: var(--cp-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* ══════════════════════════════════
     EDITOR PLACEHOLDERS
  ══════════════════════════════════ */
  .cp-placeholder {
    border: 2px dashed rgba(0,0,0,0.1);
    border-radius: 14px;
    padding: 28px 20px;
    text-align: center;
    color: rgba(0,0,0,0.28);
    font-size: 13px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .cp-placeholder svg { width: 28px; height: 28px; opacity: 0.35; }

  /* ══════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════ */
  @media (max-width: 900px) {
    .cp-body {
      grid-template-columns: 1fr;
      padding: 32px 16px 48px;
      gap: 20px;
    }
    .cp-help__cols {
      grid-template-columns: 1fr;
    }
    .cp-help__col {
      border-right: none;
      border-bottom: 1px solid var(--cp-border);
      padding: 28px 20px;
    }
    .cp-help__col:last-child { border-bottom: none; }
    .cp-help { padding: 0 16px 48px; }
  }

  @media (max-width: 600px) {
    .cp-hero { min-height: 240px; }
    .cp-hero__content { padding: 44px 16px; }
    .cp-card__inner { padding: 20px 18px 24px; }
    .cp-send__inner { padding: 20px 18px 0; }
    .cp-send__preview { padding: 28px 16px 24px; gap: 10px; }
    .cp-help__heading { font-size: clamp(20px, 6vw, 28px); }
  }

  /* hide section padding for contact page */
  .shopify-design-mode .cp-placeholder { display: flex !important; }
</style>

<div id="cp-{{ section.id }}">

  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- comment -%}═══════════════════════════
        HERO BLOCK
      ═══════════════════════════{%- endcomment -%}
      {%- when 'hero' -%}
        <div class="cp-hero" {{ block.shopify_attributes }}>
          {%- if block.settings.bg_image != blank -%}
            <img
              class="cp-hero__bg"
              src="{{ block.settings.bg_image | img_url: '1600x', crop: 'center' }}"
              srcset="
                {{ block.settings.bg_image | img_url: '800x',  crop: 'center' }} 800w,
                {{ block.settings.bg_image | img_url: '1200x', crop: 'center' }} 1200w,
                {{ block.settings.bg_image | img_url: '1600x', crop: 'center' }} 1600w
              "
              sizes="100vw"
              alt="{{ block.settings.bg_image.alt | default: block.settings.heading | escape }}"
              loading="eager"
            >
          {%- else -%}
            <div class="cp-hero__placeholder"></div>
          {%- endif -%}
          <div class="cp-hero__overlay"></div>
          <div class="cp-hero__content">
            {%- comment -%} Icon {%- endcomment -%}
            <div class="cp-hero__icon">
              {%- if block.settings.icon_image != blank -%}
                <img
                  src="{{ block.settings.icon_image | img_url: '120x120' }}"
                  alt=""
                  loading="lazy"
                >
              {%- else -%}
                {%- comment -%} Default handshake SVG {%- endcomment -%}
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 40l-8-8 4-4 8 4 8-8 8 4 6-6 4 4-14 14-8-4z"/>
                  <path d="M44 20l-8 8M26 26l-6 6"/>
                  <path d="M8 36c-2-2-2-5 0-7l16-16c2-2 5-2 7 0l4 4-16 16-6 4-5-1z"/>
                  <path d="M56 28c2 2 2 5 0 7L40 51c-2 2-5 2-7 0l-4-4 16-16 6-4 5 1z"/>
                </svg>
              {%- endif -%}
            </div>

            {%- if block.settings.heading != blank -%}
              <h1 class="cp-hero__heading">{{ block.settings.heading }}</h1>
            {%- else -%}
              <h1 class="cp-hero__heading">We're Here To Help</h1>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
              <p class="cp-hero__sub">{{ block.settings.subheading }}</p>
            {%- endif -%}
          </div>
        </div>

    {%- endcase -%}
  {%- endfor -%}

  {%- comment -%}════════════════════════════════════
    TWO-COLUMN BODY
  ════════════════════════════════════{%- endcomment -%}
  {%- if has_send or has_right_blocks -%}
    <div class="cp-body">

      {%- comment -%} LEFT COLUMN {%- endcomment -%}
      <div class="cp-left">
        {%- assign found_send = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'send_message' -%}
            {%- assign found_send = true -%}
            <div class="cp-send" {{ block.shopify_attributes }}>
              <div class="cp-send__inner">
                <p class="cp-send__heading">
                  {{ block.settings.heading | default: 'Send Us A Message' }}
                </p>
              </div>

              <div class="cp-send__preview">
                {%- comment -%} Logo or brand text {%- endcomment -%}
                {%- if block.settings.logo != blank -%}
                  <div class="cp-send__logo">
                    <img
                      src="{{ block.settings.logo | img_url: '500x', crop: 'center' }}"
                      alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
                      loading="lazy"
                    >
                  </div>
                {%- elsif block.settings.brand_text != blank -%}
                  <p class="cp-send__logo-text">{{ block.settings.brand_text }}</p>
                {%- else -%}
                  <p class="cp-send__logo-text">{{ shop.name }}</p>
                {%- endif -%}

                {%- if block.settings.card_title != blank -%}
                  <h2 class="cp-send__title">{{ block.settings.card_title }}</h2>
                {%- endif -%}

                {%- if block.settings.card_desc != blank -%}
                  <p class="cp-send__desc">{{ block.settings.card_desc }}</p>
                {%- endif -%}
              </div>

              {%- comment -%} START button {%- endcomment -%}
              <div class="cp-send__btn-wrap">
                <a
                  href="{{ block.settings.btn_url | default: '#contact-form' }}"
                  class="cp-send__btn"
                >
                  {{ block.settings.btn_label | default: 'START' }}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Placeholder in editor if no send_message block {%- endcomment -%}
        {%- unless found_send -%}
          {%- if request.design_mode -%}
            <div class="cp-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              <span>Add a "Send Message" block</span>
            </div>
          {%- endif -%}
        {%- endunless -%}
      </div>

      {%- comment -%} RIGHT COLUMN {%- endcomment -%}
      <div class="cp-right">
        {%- assign found_right = false -%}
        {%- for block in section.blocks -%}

          {%- comment -%}── Contact Info ──{%- endcomment -%}
          {%- if block.type == 'contact_info' -%}
            {%- assign found_right = true -%}
            <div class="cp-card" {{ block.shopify_attributes }}>
              <div class="cp-card__inner">
                <h3 class="cp-card__heading">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  {{ block.settings.heading | default: 'Contact Information' }}
                </h3>

                <div class="cp-info-rows">

                  {%- comment -%} Address {%- endcomment -%}
                  {%- if block.settings.address != blank -%}
                    <div class="cp-info-row">
                      <svg class="cp-info-row__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/>
                      </svg>
                      <div class="cp-info-row__body">
                        <p class="cp-info-row__label">{{ block.settings.address_label | default: 'Address' }}</p>
                        <p class="cp-info-row__content">{{ block.settings.address }}</p>
                        {%- if block.settings.address_note != blank -%}
                          <p class="cp-info-row__note">{{ block.settings.address_note }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}

                  {%- comment -%} Phone {%- endcomment -%}
                  {%- if block.settings.phone_content != blank -%}
                    <div class="cp-info-row">
                      <svg class="cp-info-row__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.09-1.09a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/>
                      </svg>
                      <div class="cp-info-row__body">
                        <p class="cp-info-row__label">{{ block.settings.phone_label | default: 'Phone' }}</p>
                        <p class="cp-info-row__content">{{ block.settings.phone_content }}</p>
                      </div>
                    </div>
                  {%- endif -%}

                  {%- comment -%} Email {%- endcomment -%}
                  {%- if block.settings.email != blank -%}
                    <div class="cp-info-row">
                      <svg class="cp-info-row__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/>
                      </svg>
                      <div class="cp-info-row__body">
                        <p class="cp-info-row__label">{{ block.settings.email_label | default: 'Email' }}</p>
                        <p class="cp-info-row__content"><a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></p>
                      </div>
                    </div>
                  {%- endif -%}

                </div>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%}── Wholesale ──{%- endcomment -%}
          {%- if block.type == 'wholesale' -%}
            {%- assign found_right = true -%}
            <div class="cp-card" {{ block.shopify_attributes }}>
              <div class="cp-card__inner">
                <h3 class="cp-card__heading">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                  {{ block.settings.heading | default: 'Wholesale Opportunities' }}
                </h3>
                {%- if block.settings.description != blank -%}
                  <p class="cp-wholesale__desc">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
                  <a href="{{ block.settings.link_url }}" class="cp-wholesale__link">
                    {{ block.settings.link_label }}
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%}── Support Hours ──{%- endcomment -%}
          {%- if block.type == 'support_hours' -%}
            {%- assign found_right = true -%}
            <div class="cp-card" {{ block.shopify_attributes }}>
              <div class="cp-card__inner">
                <h3 class="cp-card__heading">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  {{ block.settings.heading | default: 'Support Hours' }}
                </h3>

                <table class="cp-hours-table">
                  <tbody>
                    {%- if block.settings.row1_days != blank -%}
                      <tr>
                        <td>{{ block.settings.row1_days }}</td>
                        <td>{{ block.settings.row1_hours }}</td>
                      </tr>
                    {%- endif -%}
                    {%- if block.settings.row2_days != blank -%}
                      <tr>
                        <td>{{ block.settings.row2_days }}</td>
                        <td>{{ block.settings.row2_hours }}</td>
                      </tr>
                    {%- endif -%}
                    {%- if block.settings.row3_days != blank -%}
                      <tr>
                        <td>{{ block.settings.row3_days }}</td>
                        <td>{{ block.settings.row3_hours }}</td>
                      </tr>
                    {%- endif -%}
                    {%- if block.settings.row4_days != blank -%}
                      <tr>
                        <td>{{ block.settings.row4_days }}</td>
                        <td>{{ block.settings.row4_hours }}</td>
                      </tr>
                    {%- endif -%}
                  </tbody>
                </table>

                {%- if block.settings.note != blank -%}
                  <p class="cp-hours-note">{{ block.settings.note }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

        {%- endfor -%}

        {%- comment -%} Placeholder in editor if no right blocks {%- endcomment -%}
        {%- unless found_right -%}
          {%- if request.design_mode -%}
            <div class="cp-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              <span>Add info blocks (Contact Info, Wholesale, Support Hours)</span>
            </div>
          {%- endif -%}
        {%- endunless -%}
      </div>

    </div>
  {%- endif -%}

  {%- comment -%}════════════════════════════════════
    HELP STRIP (bottom)
  ════════════════════════════════════{%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'help_strip' -%}
      <div class="cp-help" {{ block.shopify_attributes }}>
        <div class="cp-help__header">
