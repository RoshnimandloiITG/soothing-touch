              {%- endif -%}
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Contact Page",
  "tag": "section",
  "class": "contact-page-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / heading color",
      "default": "#b84c3a"
    },
    {
      "type": "color",
      "id": "page_bg_color",
      "label": "Page background",
      "default": "#fdf6f3"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_main_color",
      "label": "Main text color",
      "default": "#2c1a14"
    },
    {
      "type": "color",
      "id": "text_muted_color",
      "label": "Muted / secondary text",
      "default": "#6b4c42"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "START button background",
      "default": "#b84c3a"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "START button text",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero Banner",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background image",
          "info": "Recommended: 1600 × 600 px landscape"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (optional)",
          "info": "White/light PNG icon. Leave blank for default handshake icon."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "We're Here To Help"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Your satisfaction is important to us!"
        }
      ]
    },
    {
      "type": "send_message",
      "name": "Send Message Card",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card section label",
          "default": "Send Us A Message"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo",
          "info": "Shown inside the card preview area. Leave blank to use brand text."
        },
        {
          "type": "text",
          "id": "brand_text",
          "label": "Brand name (if no logo)",
          "default": "Your Store"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card title",
          "default": "Help & Support Request"
        },
        {
          "type": "textarea",
          "id": "card_desc",
          "label": "Card description",
          "default": "We're here to help! Please click start below to begin your support request."
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label",
          "default": "START"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button link",
          "info": "Link to your helpdesk, Gorgias, or contact form."
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Information",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card heading",
          "default": "Contact Information"
        },
        {
          "type": "text",
          "id": "address_label",
          "label": "Address label",
          "default": "Address"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "placeholder": "Company Name\n123 Street\nCity, State ZIP\nCountry"
        },
        {
          "type": "text",
          "id": "address_note",
          "label": "Address note (italic)",
          "placeholder": "(Please note that our production facility is not open to the public)"
        },
        {
          "type": "text",
          "id": "phone_label",
          "label": "Phone label",
          "default": "Phone"
        },
        {
          "type": "textarea",
          "id": "phone_content",
          "label": "Phone content",
          "placeholder": "Toll Free: 800-000-0000\nLocal: (555) 000-0000",
          "info": "Use line breaks for multiple numbers."
        },
        {
          "type": "text",
          "id": "email_label",
          "label": "Email label",
          "default": "Email"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email address",
          "placeholder": "hello@yourstore.com"
        }
      ]
    },
    {
      "type": "wholesale",
      "name": "Wholesale Opportunities",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card heading",
          "default": "Wholesale Opportunities"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Are you interested in becoming a wholesale distributor for our products?\n\nWe offer competitive wholesale pricing and support for qualified retailers, spas, and wellness centers."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Fill out your application here"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "support_hours",
      "name": "Support Hours",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card heading",
          "default": "Support Hours"
        },
        {
          "type": "text",
          "id": "row1_days",
          "label": "Row 1 – Days",
          "default": "Monday – Friday"
        },
        {
          "type": "text",
          "id": "row1_hours",
          "label": "Row 1 – Hours",
          "default": "8:00 AM – 4:00 PM MST"
        },
        {
          "type": "text",
          "id": "row2_days",
          "label": "Row 2 – Days",
          "default": "Saturday – Sunday"
        },
        {
          "type": "text",
          "id": "row2_hours",
          "label": "Row 2 – Hours",
          "default": "Closed"
        },
        {
          "type": "text",
          "id": "row3_days",
          "label": "Row 3 – Days (optional)"
        },
        {
          "type": "text",
          "id": "row3_hours",
          "label": "Row 3 – Hours (optional)"
        },
        {
          "type": "text",
          "id": "row4_days",
          "label": "Row 4 – Days (optional)"
        },
        {
          "type": "text",
          "id": "row4_hours",
          "label": "Row 4 – Hours (optional)"
        },
        {
          "type": "textarea",
          "id": "note",
          "label": "Note box (below hours)",
          "default": "Email Support: We monitor emails 24/7 and respond even outside business hours for urgent issues."
        }
      ]
    },
    {
      "type": "help_strip",
      "name": "Need Help Strip",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (bold part)",
          "default": "NEED HELP RIGHT NOW"
        },
        {
          "type": "text",
          "id": "heading_suffix",
          "label": "Heading suffix (light weight)",
          "default": "?"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Our intelligent virtual assistant can likely help you with any of your questions. Call: 800-000-0000"
        },
        {
          "type": "header",
          "content": "Column 1"
        },
        {
          "type": "select",
          "id": "col1_icon",
          "label": "Icon",
          "options": [
            { "value": "box",   "label": "Box / Delivery" },
            { "value": "phone", "label": "Phone"          },
            { "value": "bag",   "label": "Shopping Bag"   },
            { "value": "mail",  "label": "Mail / Email"   }
          ],
          "default": "box"
        },
        {
          "type": "text",
          "id": "col1_label",
          "label": "Label",
          "default": "QUICK QUESTIONS"
        },
        {
          "type": "text",
          "id": "col1_desc",
          "label": "Description",
          "default": "Product info, ingredients, usage"
        },
        {
          "type": "header",
          "content": "Column 2"
        },
        {
          "type": "select",
          "id": "col2_icon",
          "label": "Icon",
          "options": [
            { "value": "phone", "label": "Phone"          },
            { "value": "box",   "label": "Box / Delivery" },
            { "value": "bag",   "label": "Shopping Bag"   },
            { "value": "mail",  "label": "Mail / Email"   }
          ],
          "default": "phone"
        },
        {
          "type": "text",
          "id": "col2_label",
          "label": "Label",
          "default": "ORDER ISSUES"
        },
        {
          "type": "text",
          "id": "col2_desc",
          "label": "Description",
          "default": "Shipping, returns, order status"
        },
        {
          "type": "header",
          "content": "Column 3"
        },
        {
          "type": "select",
          "id": "col3_icon",
          "label": "Icon",
          "options": [
            { "value": "bag",   "label": "Shopping Bag"   },
            { "value": "box",   "label": "Box / Delivery" },
            { "value": "phone", "label": "Phone"          },
            { "value": "mail",  "label": "Mail / Email"   }
          ],
          "default": "bag"
        },
        {
          "type": "text",
          "id": "col3_label",
          "label": "Label",
          "default": "BUSINESS INQUIRIES"
        },
        {
          "type": "text",
          "id": "col3_desc",
          "label": "Description",
          "default": "Wholesale, partnerships, bulk orders"
        }
      ]
    }
  ],
