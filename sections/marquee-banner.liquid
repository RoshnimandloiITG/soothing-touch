          { "value": "bottom", "label": "Bottom" }
        ],
        "default": "center"
      },
      {
        "type": "text",
        "id": "panel2_heading",
        "label": "Panel 2 — Heading",
        "info": "Leave blank to hide."
      },
      {
        "type": "textarea",
        "id": "panel2_text",
        "label": "Panel 2 — Text",
        "info": "Leave blank to hide."
      },
      {
        "type": "text",
        "id": "panel2_btn_label",
        "label": "Panel 2 — Button label",
        "info": "Leave blank to hide."
      },
      {
        "type": "url",
        "id": "panel2_btn_link",
        "label": "Panel 2 — Button link"
      },
      {
        "type": "select",
        "id": "panel2_content_pos",
        "label": "Panel 2 — Content position",
        "options": [
          { "value": "top-left",      "label": "Top Left" },
          { "value": "top-center",    "label": "Top Center" },
          { "value": "top-right",     "label": "Top Right" },
          { "value": "middle-left",   "label": "Middle Left" },
