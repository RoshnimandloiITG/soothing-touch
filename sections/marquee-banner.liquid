      },
      {
        "type": "text",
        "id": "panel2_video",
        "label": "Panel 2 — Video URL",
        "info": "Direct .mp4 URL."
      },
      {
        "type": "select",
        "id": "panel2_media_pos",
        "label": "Panel 2 — Media focal point",
        "options": [
          { "value": "top",    "label": "Top" },
