        "label": "Panel 1 — Image"
      },
      {
        "type": "text",
        "id": "panel1_video",
        "label": "Panel 1 — Video URL",
        "info": "Direct .mp4 URL."
      },
      {
        "type": "select",
        "id": "panel1_media_pos",
        "label": "Panel 1 — Media focal point",
        "options": [
          { "value": "top",    "label": "Top" },
          { "value": "center", "label": "Center" },
          { "value": "bottom", "label": "Bottom" }
        ],
        "default": "center"
      },
      {
        "type": "text",
        "id": "panel1_heading",
        "label": "Panel 1 — Heading",
        "info": "Leave blank to hide."
      },
      {
        "type": "textarea",
        "id": "panel1_text",
        "label": "Panel 1 — Text",
        "info": "Leave blank to hide."
      },
      {
        "type": "text",
        "id": "panel1_btn_label",
        "label": "Panel 1 — Button label",
        "info": "Leave blank to hide."
      },
      {
        "type": "url",
        "id": "panel1_btn_link",
        "label": "Panel 1 — Button link"
      },
      {
        "type": "select",
        "id": "panel1_content_pos",
        "label": "Panel 1 — Content position",
        "options": [
          { "value": "top-left",      "label": "Top Left" },
          { "value": "top-center",    "label": "Top Center" },
          { "value": "top-right",     "label": "Top Right" },
          { "value": "middle-left",   "label": "Middle Left" },
          { "value": "middle-center", "label": "Middle Center" },
          { "value": "middle-right",  "label": "Middle Right" },
          { "value": "bottom-left",   "label": "Bottom Left" },
          { "value": "bottom-center", "label": "Bottom Center" },
          { "value": "bottom-right",  "label": "Bottom Right" }
        ],
