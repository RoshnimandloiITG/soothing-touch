<script>
(function () {
  'use strict';

  function initSticky(sectionId) {
    var banner  = document.getElementById('banner-' + sectionId);
    if (!banner) return;

    // Only activate when sticky checkbox is on (class set by Liquid)
    if (!banner.classList.contains('dib--sticky')) return;

    // ------------------------------------------------------------------
    // Wrap banner in a sizing wrapper so the page doesn't collapse when
    // the banner goes fixed (fixed elements leave normal flow).
    // ------------------------------------------------------------------
    var wrap = document.createElement('div');
    wrap.className = 'dib--sticky-wrap';
    banner.parentNode.insertBefore(wrap, banner);
    wrap.appendChild(banner);

    function setWrapHeight() {
      wrap.style.height = banner.offsetHeight + 'px';
    }
    setWrapHeight();
    window.addEventListener('resize', setWrapHeight);

    // ------------------------------------------------------------------
    // Sentinel element — sits right after the wrapper.
    // When it scrolls above the viewport top, banner goes fixed.
    // When it comes back into view, banner returns to normal flow.
    // ------------------------------------------------------------------
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
    wrap.insertAdjacentElement('beforebegin', sentinel);

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) {
            // sentinel left viewport upward → pin banner
            banner.classList.add('dib--is-fixed');
            wrap.style.height = banner.offsetHeight + 'px'; // keep space reserved
          } else {
            // sentinel visible again → un-pin banner
            banner.classList.remove('dib--is-fixed');
          }
        });
      },
      { threshold: 0, rootMargin: '0px 0px 0px 0px' }
    );

    observer.observe(sentinel);
  }

  // Run on page load
  document.addEventListener('DOMContentLoaded', function () {
    initSticky('{{ section.id }}');
  });

  // Re-run when Shopify theme editor reloads the section
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') {
        initSticky('{{ section.id }}');
      }
    });
  }
})();
</script>


