          "max": 99,
          "step": 1,
          "label": "Horizontal position (% from left)",
          "default": 30
        },
        {
          "type": "range",
          "id": "pos_y",
          "min": 1,
          "max": 99,
          "step": 1,
          "label": "Vertical position (% from top)",
