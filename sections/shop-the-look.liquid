{% comment %}
  ╔══════════════════════════════════════════════════════════════════╗
  ║  Shop the Look — Hotspot + Floating Panel + Mobile Slider        ║
  ║  ───────────────────────────────────────────────────────────── ║
  ║  DESKTOP (>768px):                                               ║
  ║    • Full canvas image with hotspot pins                         ║
  ║    • Tilted floating product panel (left/right) on canvas        ║
  ║    • 2-col grid (auto 1/2/3 col based on block count)            ║
  ║    • Click pin → highlight matching card + vice versa            ║
  ║                                                                  ║
  ║  MOBILE (≤768px):                                                ║
  ║    • Full-width canvas image with pins                           ║
  ║    • Bottom slider row: thumb | title + stars + price            ║
  ║    • Dot pagination, swipe/drag support                          ║
  ║    • Tap pin → jump to matching slide                            ║
  ╚══════════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign panel_side = section.settings.panel_position | default: 'left'
  assign canvas_mw = section.settings.canvas_max_width | default: 1200
  assign border_r = section.settings.border_radius | default: 12
  assign block_count = section.blocks | size

  assign panel_cols = 1
  if block_count >= 2
    assign panel_cols = 2
  endif
  if block_count >= 5
    assign panel_cols = 3
  endif
-%}

<section
  class="stl color-{{ scheme }} gradient"
  id="stl-{{ section.id }}"
  data-section="{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="stl__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="stl__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="stl__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="stl__wrap" style="max-width:{{ canvas_mw }}px;">
      {%- comment -%}── Canvas: image + pins + desktop panel ──{%- endcomment -%}
      <div
        class="stl__canvas stl__canvas--{{ panel_side }}"
        id="stl-canvas-{{ section.id }}"
        style="border-radius:{{ border_r }}px {{ border_r }}px 0 0;"
      >
        {%- if section.settings.image != blank -%}
          <img
            class="stl__bg"
            src="{{ section.settings.image | img_url: '1400x', crop: 'center' }}"
            srcset="
              {{ section.settings.image | img_url: '800x',  crop: 'center' }} 800w,
              {{ section.settings.image | img_url: '1200x', crop: 'center' }} 1200w,
              {{ section.settings.image | img_url: '1600x', crop: 'center' }} 1600w
            "
            sizes="(max-width: 800px) 100vw, (max-width: 1200px) 100vw, {{ canvas_mw }}px"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
          <div class="stl__bg-overlay stl__bg-overlay--{{ panel_side }}"></div>
        {%- else -%}
          <div class="stl__bg-placeholder">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.3"
            >
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
            <span>Add a background image in section settings</span>
          </div>
        {%- endif -%}

        {%- comment -%}── Desktop floating panel ──{%- endcomment -%}
        {%- if block_count > 0 -%}
          <div
            class="stl__panel"
            id="stl-panel-{{ section.id }}"
            style="--stl-cols: {{ panel_cols }};"
            role="region"
            aria-label="Products in this look"
          >
            <div class="stl__grid">
              {%- for block in section.blocks -%}
                {%- assign p = block.settings.product -%}
                <div class="stl__pcard" data-pin="{{ block.id }}" {{ block.shopify_attributes }}>
                  {%- if p != blank -%}
                    <a href="{{ p.url }}" class="stl__pcard-link" aria-label="{{ p.title }}">
                      <div class="stl__pcard-img-wrap">
                        {%- if block.settings.sale_badge != blank -%}
                          <span class="stl__pcard-badge">{{ block.settings.sale_badge }}</span>
                        {%- endif -%}
                        {%- if p.featured_image != blank -%}
                          <img
                            class="stl__pcard-img"
                            src="{{ p.featured_image | img_url: '300x300', crop: 'center' }}"
                            alt="{{ p.featured_image.alt | default: p.title | escape }}"
                            width="150"
                            height="150"
                            loading="lazy"
                          >
                        {%- else -%}
                          <div class="stl__pcard-no-img">
                            <svg
                              width="32"
                              height="32"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.2"
                              opacity="0.35"
                            >
                              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                            </svg>
                          </div>
                        {%- endif -%}
                      </div>
                      <div class="stl__pcard-info">
                        {%- assign star_n = block.settings.star_count | default: 5 -%}
                        {%- assign rat_txt = block.settings.rating_text | default: '5.0' -%}
                        <div class="stl__stars">
                          {%- for i in (1..5) -%}
                            <svg
                              class="stl__star{% if i <= star_n %} stl__star--on{% endif %}"
                              width="11"
                              height="11"
                              viewBox="0 0 24 24"
                            >
                              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                            </svg>
                          {%- endfor -%}
                          <span class="stl__stars-val">{{ rat_txt }}</span>
                        </div>
                        <p class="stl__pcard-title">{{ p.title }}</p>
                        <p class="stl__pcard-price">
                          {%- if p.compare_at_price > p.price -%}
                            <s class="stl__pcard-price-compare">{{ p.compare_at_price | money }}</s>
                          {%- endif -%}
                          <span>{{ p.price | money }}</span>
                        </p>
                      </div>
                    </a>
                  {%- else -%}
                    <div class="stl__pcard-empty">
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.2"
                        opacity="0.3"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                      </svg>
                      <span>Select a product</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%}── Hotspot Pins ──{%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- assign px = block.settings.pos_x | default: 50 -%}
          {%- assign py = block.settings.pos_y | default: 50 -%}
          <div
            class="stl__pin"
            style="left:{{ px }}%; top:{{ py }}%;"
            data-block="{{ block.id }}"
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
            role="button"
            tabindex="0"
            aria-label="{% if block.settings.product != blank %}View {{ block.settings.product.title }}{% else %}Hotspot pin{% endif %}"
            aria-pressed="false"
          >
            <div class="stl__pin-btn" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <line x1="6" y1="1" x2="6" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="1" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="stl__pin-ring" aria-hidden="true"></div>
          </div>
        {%- endfor -%}
      </div>
      {%- comment -%}/.stl__canvas{%- endcomment -%}

      {%- comment -%}── Mobile Slider ──{%- endcomment -%}
      {%- if block_count > 0 -%}
        <div
          class="stl__ms"
          id="stl-ms-{{ section.id }}"
          style="border-radius: 0 0 {{ border_r }}px {{ border_r }}px;"
          role="region"
          aria-label="Products in this look"
        >
          <div class="stl__ms-track" id="stl-ms-track-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- assign p = block.settings.product -%}
              <div
                class="stl__ms-slide"
                data-pin="{{ block.id }}"
                data-index="{{ forloop.index0 }}"
                role="group"
                aria-label="Product {{ forloop.index }} of {{ block_count }}"
              >
                {%- if p != blank -%}
                  <a href="{{ p.url }}" class="stl__ms-row" aria-label="{{ p.title }}">
                    <div class="stl__ms-thumb">
                      {%- if p.featured_image != blank -%}
                        <img
                          src="{{ p.featured_image | img_url: '140x140', crop: 'center' }}"
                          alt="{{ p.featured_image.alt | default: p.title | escape }}"
                          width="70"
                          height="70"
                          loading="lazy"
                        >
                      {%- else -%}
                        <svg
                          width="28"
                          height="28"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.2"
                          opacity="0.3"
                        >
                          <rect x="3" y="3" width="18" height="18" rx="2"/>
                        </svg>
                      {%- endif -%}
                    </div>
                    <div class="stl__ms-info">
                      <p class="stl__ms-name">{{ p.title }}</p>
                      {%- assign star_n = block.settings.star_count | default: 5 -%}
                      {%- assign rat_txt = block.settings.rating_text | default: '5.0' -%}
                      <div class="stl__ms-stars">
                        {%- for i in (1..5) -%}
                          <svg
                            class="stl__star{% if i <= star_n %} stl__star--on{% endif %}"
                            width="13"
                            height="13"
                            viewBox="0 0 24 24"
                          >
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                          </svg>
                        {%- endfor -%}
                        <span class="stl__ms-stars-val">{{ rat_txt }}</span>
                      </div>
                    </div>
                    <div class="stl__ms-price">
                      {%- if p.compare_at_price > p.price -%}
                        <s>{{ p.compare_at_price | money }}</s>
                      {%- endif -%}
                      <strong>{{ p.price | money }}</strong>
                    </div>
                  </a>
                {%- else -%}
                  <div class="stl__ms-row stl__ms-row--empty">
                    <div class="stl__ms-thumb">
                      <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.2"
                        opacity="0.3"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                      </svg>
                    </div>
                    <div class="stl__ms-info"><p class="stl__ms-name" style="opacity:.4">Select a product</p></div>
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>

          {%- if block_count > 1 -%}
            <div class="stl__ms-dots" role="tablist" aria-label="Slide navigation">
              {%- for block in section.blocks -%}
                <button
                  class="stl__ms-dot{% if forloop.first %} is-active{% endif %}"
                  data-goto="{{ forloop.index0 }}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="Product {{ forloop.index }}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    {%- comment -%}/.stl__wrap{%- endcomment -%}
  </div>
</section>

<style>
  /* ════════════════════════════════════════
   BASE
════════════════════════════════════════ */
  .stl {
    background: var(--stl-bg);
    color: var(--stl-text);
    padding: 60px 0;
  }
  .stl__wrap {
    width: 100%;
    margin: 0 auto;
  }

  .stl__header {
    text-align: center;
    padding: 0 20px;
    margin-bottom: 36px;
  }
  .stl__title {
    font-size: clamp(22px, 4vw, 40px);
    font-weight: 800;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .stl__sub {
    font-size: clamp(13px, 1.6vw, 16px);
    margin: 0;
    opacity: 0.65;
    line-height: 1.5;
  }

  /* ════════════════════════════════════════
   CANVAS
════════════════════════════════════════ */
  .stl__canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .stl__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .stl__bg-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .stl__bg-overlay--left {
    background: var(--stl-ov-l);
  }
  .stl__bg-overlay--right {
    background: var(--stl-ov-r);
  }
  .stl__bg-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    background: var(--stl-panel-bg);
    color: var(--stl-text);
    font-size: 13px;
    opacity: 0.5;
  }

  /* ════════════════════════════════════════
   DESKTOP PANEL — tilted
════════════════════════════════════════ */
  .stl__panel {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    padding: 14px;
    background: rgba(var(--color-background), 0.36);
    border-radius: 20px;
    box-shadow: var(--stl-panel-shadow);
    border: 1px solid var(--stl-panel-border);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    max-height: calc(100% - 40px);
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .stl__panel::-webkit-scrollbar {
    display: none;
  }
  .stl__canvas--left .stl__panel {
    left: 22px;
  }
  .stl__canvas--right .stl__panel {
    right: 22px;
  }

  .stl__grid {
    display: grid;
    grid-template-columns: repeat(var(--stl-cols, 2), 172px);
    gap: 10px;
  }

  /* ════════════════════════════════════════
   DESKTOP PRODUCT CARDS
════════════════════════════════════════ */
  .stl__pcard {
    background: rgb(var(--color-background));
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--stl-card-border);
    box-shadow: var(--stl-card-shadow);
    transition: transform 0.22s cubic-bezier(0.34, 1.4, 0.64, 1), box-shadow 0.22s ease, outline-color 0.15s ease;
    outline: 2.5px solid transparent;
    outline-offset: 0;
  }
  .stl__pcard:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.13);
  }
  .stl__pcard.is-active {
    outline-color: var(--stl-active-ring);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }
  .stl__pcard-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color:rgb(var(--color-foreground));
    height: 100%;
  }
  .stl__pcard-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    flex-shrink: 0;
  }
  .stl__pcard-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.38s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .stl__pcard:hover .stl__pcard-img {
    transform: scale(1.06);
  }
  .stl__pcard-no-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--stl-text);
  }
  .stl__pcard-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--stl-badge-bg);
    color: var(--stl-badge-fg);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 7px;
    line-height: 1;
    z-index: 2;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }
  .stl__pcard-info {
    padding: 10px 12px 13px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stl__pcard-title {
    font-size: 12px;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    color: var(--stl-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .stl__pcard-price {
    font-size: 13px;
    font-weight: 700;
    margin: 0;
    color: var(--stl-price);
    display: flex;
    align-items: baseline;
    gap: 5px;
    flex-wrap: wrap;
  }
  .stl__pcard-price-compare {
    font-size: 11px;
    font-weight: 400;
    opacity: 0.42;
    text-decoration: line-through;
  }
  .stl__pcard-empty {
    padding: 20px 16px;
    width: 172px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 11px;
    opacity: 0.4;
    color: var(--stl-text);
    text-align: center;
    aspect-ratio: 1;
  }

  /* Shared stars */
  .stl__stars,
  .stl__ms-stars {
    display: flex;
    align-items: center;
    gap: 1.5px;
  }
  .stl__star {
    display: block;
    flex-shrink: 0;
    color: var(--stl-star-off);
  }
  .stl__star--on {
    color: var(--stl-star-on);
  }
  .stl__stars-val {
    font-size: 10.5px;
    font-weight: 600;
    color: var(--stl-text);
    opacity: 0.62;
    margin-left: 4px;
    white-space: nowrap;
  }

  /* ════════════════════════════════════════
   HOTSPOT PINS
════════════════════════════════════════ */
  .stl__pin {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 20;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }
  .stl__pin:focus-visible .stl__pin-btn {
    box-shadow: 0 0 0 3px var(--stl-active-ring), var(--stl-pin-shadow);
  }
  .stl__pin-btn {
    position: relative;
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--stl-pin-shadow);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s ease, color 0.25s ease,
      box-shadow 0.25s ease;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .stl__pin:hover .stl__pin-btn {
    transform: scale(1.2);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.38);
  }
  .stl__pin.is-active .stl__pin-btn {
    transform: scale(1.15) rotate(45deg);
    background: var(--stl-active-ring);
    color: #fff;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }
  .stl__pin-ring {
    position: absolute;
    inset: -7px;
    border-radius: 50%;
    background: var(--stl-pin-ring);
    z-index: 1;
    pointer-events: none;
    animation: stl-pulse 2.6s ease-in-out infinite;
  }
  .stl__pin.is-active .stl__pin-ring {
    animation: none;
    opacity: 0;
  }
  @keyframes stl-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.65;
    }
    50% {
      transform: scale(1.75);
      opacity: 0;
    }
  }

  /* ════════════════════════════════════════
   MOBILE SLIDER  (hidden on desktop)
════════════════════════════════════════ */
  .stl__ms {
    display: none;
    background: var(--stl-ms-bg);
    overflow: hidden;
  }

  /* Sliding track */
  .stl__ms-track {
    display: flex;
    will-change: transform;
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* One slide = full width */
  .stl__ms-slide {
    min-width: 100%;
    flex-shrink: 0;
    padding: 16px 18px 10px;
    box-sizing: border-box;
  }

  /* Row inside slide */
  .stl__ms-row {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--stl-text);
  }
  .stl__ms-row--empty {
    opacity: 0.4;
    pointer-events: none;
  }

  /* Thumbnail */
  .stl__ms-thumb {
    width: 76px;
    height: 76px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--stl-card-bg);
    border: 1px solid var(--stl-card-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stl__ms-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Info */
  .stl__ms-info {
    flex: 1;
    min-width: 0;
  }
  .stl__ms-name {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--stl-text);
  }
  .stl__ms-stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .stl__ms-stars-val {
    font-size: 12px;
    font-weight: 600;
    color: var(--stl-text);
    opacity: 0.6;
    margin-left: 5px;
  }

  /* Price — right side */
  .stl__ms-price {
    margin-left: auto;
    flex-shrink: 0;
    text-align: right;
  }
  .stl__ms-price strong {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--stl-price);
  }
  .stl__ms-price s {
    font-size: 11px;
    opacity: 0.4;
    text-decoration: line-through;
  }

  /* Dots */
  .stl__ms-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 7px;
    padding: 8px 0 16px;
  }
  .stl__ms-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--stl-dot);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease, width 0.25s ease, border-radius 0.25s ease;
    flex-shrink: 0;
  }
  .stl__ms-dot.is-active {
    background: var(--stl-dot-on);
    width: 24px;
    border-radius: 4px;
  }

  /* ════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════ */
  @media (max-width: 1000px) {
    .stl__grid {
      grid-template-columns: repeat(var(--stl-cols, 2), 148px);
    }
    .stl__pcard-empty {
      width: 148px;
    }
  }

  @media (max-width: 768px) {
    /* Remove section padding — slider connects flush to canvas */
    .stl {
      padding: 0;
    }

    /* Canvas fills width, portrait ratio */
    .stl__canvas {
      aspect-ratio: 4 / 2;
      border-radius: 0 !important;
    }

    /* Hide desktop panel */
    .stl__panel {
      display: none !important;
    }

    /* Show mobile slider */
    .stl__ms {
      display: block;
    }

    /* No overlay */
    .stl__bg-overlay {
      display: none;
    }

    /* Smaller pins */
    .stl__pin-btn {
      width: 30px;
      height: 30px;
    }

    /* Section header restore padding */
    .stl__header {
      padding-top: 32px;
    }
  }

  @media (max-width: 480px) {
    .stl__canvas {
      aspect-ratio: 1 / 1;
    }
    .stl__ms-thumb {
      width: 62px;
      height: 62px;
      border-radius: 10px;
    }
    .stl__ms-name {
      font-size: 13px;
    }
    .stl__ms-price strong {
      font-size: 14px;
    }
    .stl__ms-slide {
      padding: 13px 14px 8px;
    }
    .stl__pin-btn {
      width: 26px;
      height: 26px;
    }
  }

  /* Shopify editor */
  .shopify-design-mode .stl__pin {
    pointer-events: auto;
  }
</style>

<script>
  (function () {
    'use strict';

    var sEl = document.getElementById('stl-{{ section.id }}');
    if (!sEl) return;

    /* ── Utility: set all pin/card active states ── */
    function clearAll() {
      sEl.querySelectorAll('.stl__pin').forEach(function (p) {
        p.classList.remove('is-active');
        p.setAttribute('aria-pressed', 'false');
      });
      sEl.querySelectorAll('.stl__pcard').forEach(function (c) {
        c.classList.remove('is-active');
      });
    }

    /* ══════════════════════════════════
     DESKTOP INTERACTION
  ══════════════════════════════════ */
    function initDesktop() {
      var pins = Array.prototype.slice.call(sEl.querySelectorAll('.stl__pin'));
      var cards = Array.prototype.slice.call(sEl.querySelectorAll('.stl__pcard'));
      var panel = sEl.querySelector('.stl__panel');

      function activateBlock(blockId) {
        clearAll();
        var pin = sEl.querySelector('.stl__pin[data-block="' + blockId + '"]');
        var card = sEl.querySelector('.stl__pcard[data-pin="' + blockId + '"]');
        if (pin) {
          pin.classList.add('is-active');
          pin.setAttribute('aria-pressed', 'true');
        }
        if (card) {
          card.classList.add('is-active');
          if (panel && window.innerWidth > 768)
            panel.scrollTo({ top: card.offsetTop - panel.offsetTop - 14, behavior: 'smooth' });
        }
      }

      pins.forEach(function (pin) {
        pin.addEventListener('click', function (e) {
          if (window.innerWidth <= 768) return; /* handed off to mobile slider */
          e.stopPropagation();
          pin.classList.contains('is-active') ? clearAll() : activateBlock(pin.dataset.block);
        });
        pin.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            pin.click();
          }
          if (e.key === 'Escape') clearAll();
        });
      });

      /* Card hover → hint pin */
      cards.forEach(function (card) {
        card.addEventListener('mouseenter', function () {
          var p = sEl.querySelector('.stl__pin[data-block="' + card.dataset.pin + '"]');
          if (p && !p.classList.contains('is-active')) p.querySelector('.stl__pin-btn').style.transform = 'scale(1.15)';
        });
        card.addEventListener('mouseleave', function () {
          var p = sEl.querySelector('.stl__pin[data-block="' + card.dataset.pin + '"]');
          if (p && !p.classList.contains('is-active')) p.querySelector('.stl__pin-btn').style.transform = '';
        });
      });

      document.addEventListener('click', clearAll);
      return { activateBlock: activateBlock };
    }

    /* ══════════════════════════════════
     MOBILE SLIDER
  ══════════════════════════════════ */
    function initMobile() {
      var track = document.getElementById('stl-ms-track-{{ section.id }}');
      if (!track) return null;

      var slides = Array.prototype.slice.call(track.querySelectorAll('.stl__ms-slide'));
      var dots = Array.prototype.slice.call(sEl.querySelectorAll('.stl__ms-dot'));
      var pins = Array.prototype.slice.call(sEl.querySelectorAll('.stl__pin'));
      var total = slides.length;
      var cur = 0;

      function goTo(idx) {
        idx = Math.max(0, Math.min(total - 1, idx));
        cur = idx;

        /* Slide track */
        track.style.transition = 'transform .38s cubic-bezier(.4,0,.2,1)';
        track.style.transform = 'translateX(-' + idx * 100 + '%)';

        /* Dots */
        dots.forEach(function (d, i) {
          d.classList.toggle('is-active', i === idx);
          d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
        });

        /* Highlight pin */
        pins.forEach(function (p) {
          var match = parseInt(p.dataset.index, 10) === idx;
          p.classList.toggle('is-active', match);
          p.setAttribute('aria-pressed', match ? 'true' : 'false');
        });
      }

      /* Dot clicks */
      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          goTo(parseInt(dot.dataset.goto, 10));
        });
      });

      /* Pin tap → navigate to slide */
      pins.forEach(function (pin) {
        pin.addEventListener('click', function (e) {
          if (window.innerWidth > 768) return;
          e.stopPropagation();
          goTo(parseInt(pin.dataset.index, 10));
        });
      });

      /* Touch swipe */
      var startX = 0,
        startY = 0,
        isDragging = false,
        dX = 0;
      track.addEventListener(
        'touchstart',
        function (e) {
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
          isDragging = true;
          dX = 0;
          track.style.transition = 'none';
        },
        { passive: true }
      );

      track.addEventListener(
        'touchmove',
        function (e) {
          if (!isDragging) return;
          dX = e.touches[0].clientX - startX;
          var dY = e.touches[0].clientY - startY;
          if (Math.abs(dX) > Math.abs(dY)) e.preventDefault();
          var pct = -(cur * 100) + (dX / (track.parentElement.offsetWidth || 1)) * 100;
          track.style.transform = 'translateX(' + pct + '%)';
        },
        { passive: false }
      );

      track.addEventListener('touchend', function () {
        isDragging = false;
        var threshold = (track.parentElement.offsetWidth || 300) * 0.2;
        if (dX < -threshold) goTo(cur + 1);
        else if (dX > threshold) goTo(cur - 1);
        else goTo(cur);
      });

      goTo(0);
      return { goTo: goTo };
    }

    /* ══════════════════════════════════
     BOOT
  ══════════════════════════════════ */
    var mobileCtrl;

    function init() {
      initDesktop();
      mobileCtrl = initMobile();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    /* ── Shopify editor ── */
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === '{{ section.id }}') init();
    });

    document.addEventListener('shopify:block:select', function (e) {
      var blockId = e.detail.blockId;
      clearAll();
      var pin = sEl.querySelector('.stl__pin[data-block="' + blockId + '"]');
      var card = sEl.querySelector('.stl__pcard[data-pin="' + blockId + '"]');
      if (pin) {
        pin.classList.add('is-active');
        pin.setAttribute('aria-pressed', 'true');
      }
      if (card) {
        card.classList.add('is-active');
      }
      /* Sync mobile slider */
      if (mobileCtrl && pin) mobileCtrl.goTo(parseInt(pin.dataset.index, 10));
    });

    document.addEventListener('shopify:block:deselect', function () {
      clearAll();
    });
  })();
</script>

