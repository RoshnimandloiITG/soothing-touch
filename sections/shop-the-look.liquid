{
  "name": "Shop the Look",
  "tag": "section",
  "class": "stl-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: at least 1400 × 800 px"
    },
    {
      "type": "header",
      "content": "Canvas Layout"
    },
    {
      "type": "select",
      "id": "canvas_ratio",
      "label": "Desktop aspect ratio",
      "options": [
        { "value": "16/9", "label": "Landscape 16:9" },
        { "value": "4/3", "label": "Landscape 4:3" },
        { "value": "3/2", "label": "Landscape 3:2" },
        { "value": "1/1", "label": "Square 1:1" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "3/4", "label": "Portrait 3:4" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "canvas_max_width",
      "min": 600,
      "max": 1800,
      "step": 50,
      "label": "Max canvas width (px)",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "label": "Corner radius (px)",
      "default": 12
    },
    {
      "type": "header",
      "content": "Product Panel"
    },
    {
      "type": "select",
