{% comment %}
  ╔══════════════════════════════════════════════════════════════════╗
  ║  Banner + Overlapping Products                                   ║
  ║  ─────────────────────────────────────────────────────────────  ║
  ║  • Full-width banner image with heading / subheading / button    ║
  ║  • Product cards overlap the bottom edge of the banner          ║
  ║  • Dynamic: 1-6 product blocks, auto grid columns               ║
  ║  • Per-card: sale badge, star rating, add-to-cart button        ║
  ║  • 5 colour schemes + custom text/button colour pickers         ║
  ║  • Responsive: cards stack below banner on mobile               ║
  ║  • Full Shopify editor support                                   ║
  ╚══════════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign scheme     = section.settings.color_scheme | default: 'scheme-1'
  assign blk_count  = section.blocks | size
  assign img_ratio  = section.settings.banner_ratio  | default: '50'
  assign text_align = section.settings.text_align    | default: 'center'
-%}

<section
  class="bwp color-{{ scheme }}"
  id="bwp-{{ section.id }}"
>

  {%- comment -%}════════ BANNER ════════{%- endcomment -%}
  <div
    class="bwp__banner"
    style="padding-bottom: {{ img_ratio }}%;"
  >
    {%- comment -%} Background image {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <img
        class="bwp__banner-img"
        src="{{ section.settings.image | img_url: '1600x', crop: 'center' }}"
        srcset="
          {{ section.settings.image | img_url: '800x',  crop: 'center' }} 800w,
          {{ section.settings.image | img_url: '1200x', crop: 'center' }} 1200w,
          {{ section.settings.image | img_url: '1600x', crop: 'center' }} 1600w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <div class="bwp__banner-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.35">
          <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>Add a banner image in section settings</span>
      </div>
    {%- endif -%}

    {%- comment -%} Gradient overlay {%- endcomment -%}
    <div class="bwp__banner-overlay"></div>

    {%- comment -%} Text content {%- endcomment -%}
    <div class="bwp__banner-content bwp__banner-content--{{ text_align }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="bwp__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="bwp__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="bwp__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
        <a class="bwp__btn" href="{{ section.settings.btn_url }}">
          {{ section.settings.btn_label }}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>{%- comment -%}/.bwp__banner{%- endcomment -%}

  {%- comment -%}════════ PRODUCT CARDS ════════{%- endcomment -%}
  {%- if blk_count > 0 -%}
    <div
      class="bwp__cards-outer"
      style="--bwp-cols: {{ blk_count | at_most: 4 }};"
    >
      <div class="bwp__cards page-width">
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          <div
            class="bwp__card"
            {{ block.shopify_attributes }}
          >
            {%- if p != blank -%}

              {%- comment -%} Image {%- endcomment -%}
              <a href="{{ p.url }}" class="bwp__card-img-wrap" tabindex="-1" aria-hidden="true">
                {%- if block.settings.badge != blank -%}
                  <span class="bwp__card-badge">{{ block.settings.badge }}</span>
                {%- endif -%}
                {%- if p.featured_image != blank -%}
                  <img
                    class="bwp__card-img"
                    src="{{ p.featured_image | img_url: '400x400', crop: 'center' }}"
                    alt="{{ p.featured_image.alt | default: p.title | escape }}"
                    width="200" height="200"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="bwp__card-no-img">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.3">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </a>

              {%- comment -%} Info {%- endcomment -%}
              <div class="bwp__card-info">

                {%- comment -%} Stars {%- endcomment -%}
                {%- assign star_n  = block.settings.star_count  | default: 5 -%}
                {%- assign rat_txt = block.settings.rating_text | default: '5.0' -%}
                {%- if block.settings.show_rating -%}
                  <div class="bwp__stars" aria-label="{{ star_n }} out of 5 stars">
                    {%- for i in (1..5) -%}
                      <svg class="bwp__star{% if i <= star_n %} bwp__star--on{% endif %}" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                      </svg>
                    {%- endfor -%}
                    <span class="bwp__stars-val">{{ rat_txt }}</span>
                  </div>
                {%- endif -%}

                <a href="{{ p.url }}" class="bwp__card-title">{{ p.title }}</a>

                <div class="bwp__card-price">
                  {%- if p.compare_at_price > p.price -%}
                    <s class="bwp__card-compare">{{ p.compare_at_price | money }}</s>
                  {%- endif -%}
                  <span class="bwp__card-current">{{ p.price | money }}</span>
                </div>

                {%- comment -%} Add to cart {%- endcomment -%}
                {%- if section.settings.show_atc -%}
                  {%- if p.variants.size == 1 and p.variants.first.available -%}
                    <form action="/cart/add" method="post" class="bwp__atc-form">
                      <input type="hidden" name="id" value="{{ p.variants.first.id }}">
                      <button type="submit" class="bwp__atc-btn" name="add">
                        {{ section.settings.atc_label | default: 'Add to Cart' }}
                      </button>
                    </form>
                  {%- elsif p.available -%}
                    <a href="{{ p.url }}" class="bwp__atc-btn bwp__atc-btn--link">
                      {{ section.settings.select_label | default: 'Select Options' }}
                    </a>
                  {%- else -%}
                    <span class="bwp__atc-btn bwp__atc-btn--sold">
                      {{ section.settings.sold_label | default: 'Sold Out' }}
                    </span>
                  {%- endif -%}
                {%- endif -%}

              </div>{%- comment -%}/.bwp__card-info{%- endcomment -%}

            {%- else -%}

              {%- comment -%} Empty placeholder {%- endcomment -%}
              <div class="bwp__card-placeholder">
                <div class="bwp__card-img-wrap">
                  <div class="bwp__card-no-img">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.25">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                </div>
                <div class="bwp__card-info">
                  <p class="bwp__card-title" style="opacity:.35;">Select a product</p>
                </div>
              </div>

            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

<style>
/* ══════════════════════════════════════════════════
   COLOR SCHEMES
══════════════════════════════════════════════════ */
.bwp.color-scheme-1 {
  --bwp-section-bg:     #fdf6f3;
  --bwp-overlay:        linear-gradient(to top, rgba(20,10,5,0.68) 0%, rgba(20,10,5,0.18) 60%, transparent 100%);
  --bwp-card-bg:        #ffffff;
  --bwp-card-border:    rgba(0,0,0,0.07);
  --bwp-card-shadow:    0 4px 24px rgba(0,0,0,0.09), 0 1px 4px rgba(0,0,0,0.05);
  --bwp-card-shadow-h:  0 12px 40px rgba(0,0,0,0.14);
  --bwp-card-img-bg:    #f5f0ec;
  --bwp-text:           #2c1a14;
  --bwp-text-muted:     rgba(44,26,20,0.55);
  --bwp-badge-bg:       #e8836b;
  --bwp-badge-fg:       #fff;
  --bwp-star-on:        #f0a96b;
  --bwp-star-off:       #e2d8d2;
  --bwp-price:          #2c1a14;
  --bwp-compare:        rgba(44,26,20,0.38);
  --bwp-btn-bg:         #2c1a14;
  --bwp-btn-fg:         #fff;
  --bwp-btn-bg-h:       #e8836b;
  --bwp-atc-bg:         #2c1a14;
  --bwp-atc-fg:         #fff;
  --bwp-atc-bg-h:       #e8836b;
  --bwp-placeholder-bg: #e8dbd4;
}
.bwp.color-scheme-2 {
  --bwp-section-bg:     #ffffff;
  --bwp-overlay:        linear-gradient(to top, rgba(10,10,10,0.65) 0%, rgba(10,10,10,0.15) 60%, transparent 100%);
  --bwp-card-bg:        #fff;
  --bwp-card-border:    rgba(0,0,0,0.07);
  --bwp-card-shadow:    0 4px 24px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
  --bwp-card-shadow-h:  0 12px 40px rgba(0,0,0,0.13);
  --bwp-card-img-bg:    #f2f2f2;
  --bwp-text:           #111;
  --bwp-text-muted:     rgba(17,17,17,0.5);
  --bwp-badge-bg:       #d94f35;
  --bwp-badge-fg:       #fff;
  --bwp-star-on:        #f4a522;
  --bwp-star-off:       #ddd;
  --bwp-price:          #111;
  --bwp-compare:        rgba(0,0,0,0.35);
  --bwp-btn-bg:         #111;
  --bwp-btn-fg:         #fff;
  --bwp-btn-bg-h:       #d94f35;
  --bwp-atc-bg:         #111;
  --bwp-atc-fg:         #fff;
  --bwp-atc-bg-h:       #d94f35;
  --bwp-placeholder-bg: #e8e8e8;
}
.bwp.color-scheme-3 {
  --bwp-section-bg:     #f5ede8;
  --bwp-overlay:        linear-gradient(to top, rgba(30,12,6,0.7) 0%, rgba(30,12,6,0.15) 60%, transparent 100%);
  --bwp-card-bg:        #fff;
  --bwp-card-border:    rgba(44,26,20,0.07);
  --bwp-card-shadow:    0 4px 24px rgba(44,26,20,0.1);
  --bwp-card-shadow-h:  0 12px 40px rgba(44,26,20,0.16);
  --bwp-card-img-bg:    #f8f2ef;
  --bwp-text:           #2c1a14;
  --bwp-text-muted:     rgba(44,26,20,0.5);
  --bwp-badge-bg:       #c85a3e;
  --bwp-badge-fg:       #fff;
  --bwp-star-on:        #e09458;
  --bwp-star-off:       #ddd4ce;
  --bwp-price:          #2c1a14;
  --bwp-compare:        rgba(44,26,20,0.38);
  --bwp-btn-bg:         #2c1a14;
  --bwp-btn-fg:         #fff;
  --bwp-btn-bg-h:       #c85a3e;
  --bwp-atc-bg:         #2c1a14;
  --bwp-atc-fg:         #fff;
  --bwp-atc-bg-h:       #c85a3e;
  --bwp-placeholder-bg: #ecddd6;
}
.bwp.color-scheme-4 {
  --bwp-section-bg:     #1a0e0a;
  --bwp-overlay:        linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  --bwp-card-bg:        #2a1810;
  --bwp-card-border:    rgba(255,255,255,0.1);
  --bwp-card-shadow:    0 4px 24px rgba(0,0,0,0.3);
  --bwp-card-shadow-h:  0 12px 40px rgba(0,0,0,0.45);
  --bwp-card-img-bg:    #1e120c;
  --bwp-text:           #fdf6f3;
  --bwp-text-muted:     rgba(253,246,243,0.5);
  --bwp-badge-bg:       #e8836b;
  --bwp-badge-fg:       #fff;
  --bwp-star-on:        #f0a96b;
  --bwp-star-off:       rgba(255,255,255,0.2);
  --bwp-price:          #fdf6f3;
  --bwp-compare:        rgba(253,246,243,0.35);
  --bwp-btn-bg:         #e8836b;
  --bwp-btn-fg:         #fff;
  --bwp-btn-bg-h:       #fdf6f3;
  --bwp-atc-bg:         #e8836b;
  --bwp-atc-fg:         #fff;
  --bwp-atc-bg-h:       #fdf6f3;
  --bwp-placeholder-bg: #1e120c;
}
.bwp.color-scheme-5 {
  --bwp-section-bg:     #0d0d0d;
  --bwp-overlay:        linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  --bwp-card-bg:        #1a1a1a;
  --bwp-card-border:    rgba(255,255,255,0.1);
  --bwp-card-shadow:    0 4px 24px rgba(0,0,0,0.4);
  --bwp-card-shadow-h:  0 12px 40px rgba(0,0,0,0.55);
  --bwp-card-img-bg:    #111;
  --bwp-text:           #f5f5f5;
  --bwp-text-muted:     rgba(245,245,245,0.45);
  --bwp-badge-bg:       #e05a3a;
  --bwp-badge-fg:       #fff;
  --bwp-star-on:        #f4a522;
  --bwp-star-off:       rgba(255,255,255,0.15);
  --bwp-price:          #f5f5f5;
  --bwp-compare:        rgba(245,245,245,0.3);
  --bwp-btn-bg:         #f5f5f5;
  --bwp-btn-fg:         #0d0d0d;
  --bwp-btn-bg-h:       #f4a522;
  --bwp-atc-bg:         #f5f5f5;
  --bwp-atc-fg:         #0d0d0d;
  --bwp-atc-bg-h:       #f4a522;
  --bwp-placeholder-bg: #111;
}

/* ══════════════════════════════════════════════════
   SECTION BASE
══════════════════════════════════════════════════ */
.bwp {
  background: var(--bwp-section-bg);
  color: var(--bwp-text);
  padding-bottom: 60px;
  overflow: hidden;
}

/* ══════════════════════════════════════════════════
   BANNER
══════════════════════════════════════════════════ */
.bwp__banner {
  position: relative;
  width: 100%;
  /* padding-bottom = % set inline = controls height */
}

/* Keep image filling the banner box */
.bwp__banner-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.bwp__banner-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  background: var(--bwp-placeholder-bg);
  color: var(--bwp-text);
  font-size: 13px;
  opacity: 0.6;
}

/* Gradient overlay — makes text readable + bottom fade for cards */
.bwp__banner-overlay {
  position: absolute;
  inset: 0;
  background: var(--bwp-overlay);
  z-index: 1;
  pointer-events: none;
}

/* Text content */
.bwp__banner-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: clamp(24px, 5vw, 80px);
  padding-bottom: clamp(60px, 10vw, 120px); /* extra bottom space for cards overlap */
}
.bwp__banner-content--center {
  align-items: center;
  text-align: center;
}
.bwp__banner-content--left {
  align-items: flex-start;
  text-align: left;
}
.bwp__banner-content--right {
  align-items: flex-end;
  text-align: right;
}

/* Eyebrow */
.bwp__eyebrow {
  font-size: clamp(11px, 1.2vw, 13px);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin: 0 0 12px;
}

/* Heading */
.bwp__heading {
  font-size: clamp(28px, 5.5vw, 72px);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: #fff;
  margin: 0 0 14px;
  max-width: 18ch;
  text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}
.bwp__banner-content--center .bwp__heading { max-width: 24ch; }

/* Subheading */
.bwp__subheading {
  font-size: clamp(13px, 1.6vw, 18px);
  color: rgba(255,255,255,0.82);
  margin: 0 0 28px;
  max-width: 48ch;
  line-height: 1.55;
}

/* CTA Button */
.bwp__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--bwp-btn-bg);
  color: var(--bwp-btn-fg);
  font-size: clamp(13px, 1.3vw, 15px);
  font-weight: 700;
  letter-spacing: 0.02em;
  text-decoration: none;
  padding: 14px 28px;
  border-radius: 50px;
  transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 4px 20px rgba(0,0,0,0.25);
  white-space: nowrap;
}
.bwp__btn:hover {
  background: var(--bwp-btn-bg-h);
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.3);
}
.bwp__btn svg { flex-shrink: 0; transition: transform 0.2s ease; }
.bwp__btn:hover svg { transform: translateX(3px); }

/* ══════════════════════════════════════════════════
   CARDS OUTER WRAPPER — overlaps banner
══════════════════════════════════════════════════ */
.bwp__cards-outer {
  position: relative;
  z-index: 10;
  margin-top: clamp(-120px, -14vw, -80px); /* negative margin = overlap */
}

.bwp__cards {
  display: grid;
  grid-template-columns: repeat(var(--bwp-cols, 4), 1fr);
  gap: clamp(12px, 1.8vw, 20px);
  padding: 0 clamp(16px, 4vw, 40px);
  max-width: 1300px;
  margin: 0 auto;
}

/* ══════════════════════════════════════════════════
   PRODUCT CARD
══════════════════════════════════════════════════ */
.bwp__card {
  background: var(--bwp-card-bg);
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid var(--bwp-card-border);
  box-shadow: var(--bwp-card-shadow);
  display: flex;
  flex-direction: column;
  transition: transform 0.28s cubic-bezier(0.34,1.4,0.64,1),
              box-shadow 0.28s ease;
}
.bwp__card:hover {
  transform: translateY(-6px);
  box-shadow: var(--bwp-card-shadow-h);
}

/* Image wrap */
.bwp__card-img-wrap {
  position: relative;
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--bwp-card-img-bg);
  overflow: hidden;
  text-decoration: none;
  flex-shrink: 0;
}
.bwp__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
}
.bwp__card:hover .bwp__card-img { transform: scale(1.07); }
.bwp__card-no-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: var(--bwp-text);
}

/* Badge */
.bwp__card-badge {
  position: absolute;
  top: 10px; left: 10px;
  background: var(--bwp-badge-bg);
  color: var(--bwp-badge-fg);
  font-size: 10px; font-weight: 800;
  letter-spacing: 0.05em; text-transform: uppercase;
  padding: 5px 9px; border-radius: 8px; line-height: 1;
  z-index: 2; white-space: nowrap;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

/* Info area */
.bwp__card-info {
  padding: clamp(12px,1.6vw,16px);
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

/* Stars */
.bwp__stars {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-wrap: nowrap;
}
.bwp__star { display: block; flex-shrink: 0; color: var(--bwp-star-off); }
.bwp__star--on { color: var(--bwp-star-on); }
.bwp__stars-val {
  font-size: 11px; font-weight: 600;
  color: var(--bwp-text); opacity: 0.58;
  margin-left: 5px; white-space: nowrap;
}

/* Title */
.bwp__card-title {
  font-size: clamp(13px,1.3vw,15px);
  font-weight: 600;
  line-height: 1.35;
  color: var(--bwp-text);
  text-decoration: none;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: opacity 0.18s;
}
.bwp__card-title:hover { opacity: 0.7; }

/* Price */
.bwp__card-price {
  display: flex;
  align-items: baseline;
  gap: 7px;
  flex-wrap: wrap;
  margin-top: auto;
  padding-top: 2px;
}
.bwp__card-current {
  font-size: clamp(14px,1.5vw,17px);
  font-weight: 800;
  color: var(--bwp-price);
}
.bwp__card-compare {
  font-size: 12px;
  font-weight: 400;
  color: var(--bwp-compare);
  text-decoration: line-through;
}

/* Add to cart button */
.bwp__atc-btn {
  display: block;
  width: 100%;
  margin-top: 10px;
  padding: 11px 14px;
  background: var(--bwp-atc-bg);
  color: var(--bwp-atc-fg);
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.22s ease, transform 0.18s ease;
  line-height: 1;
}
.bwp__atc-btn:hover { background: var(--bwp-atc-bg-h); transform: translateY(-1px); }
.bwp__atc-btn--sold {
  opacity: 0.45;
  cursor: not-allowed;
  pointer-events: none;
}
.bwp__atc-form { margin: 0; }

/* Empty card placeholder */
.bwp__card-placeholder {
  display: flex; flex-direction: column; flex: 1;
}

/* ══════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════ */

/* 3 cols at 3-4 products on medium screens */
@media (max-width: 1100px) {
  .bwp__cards {
    grid-template-columns: repeat(
      min(var(--bwp-cols, 4), 3), 1fr
    );
  }
}

@media (max-width: 768px) {
  .bwp { padding-bottom: 40px; }

  /* Banner taller on mobile */
  .bwp__banner { padding-bottom: 75% !important; }

  /* Less bottom padding in text, cards overlap less */
  .bwp__banner-content {
    padding: 24px 20px 80px;
  }

  /* 2-col grid */
  .bwp__cards {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 12px;
    padding: 0 14px;
  }

  /* Reduce overlap on mobile */
  .bwp__cards-outer {
    margin-top: -50px;
  }

  .bwp__heading { font-size: clamp(24px,7vw,36px); }
  .bwp__subheading { font-size: 13px; margin-bottom: 20px; }
  .bwp__btn { padding: 12px 22px; font-size: 13px; }
}

@media (max-width: 480px) {
  .bwp__banner { padding-bottom: 100% !important; }
  .bwp__cards {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 10px;
    padding: 0 10px;
  }
  .bwp__cards-outer { margin-top: -40px; }
  .bwp__card-info { padding: 10px 11px 12px; gap: 5px; }
  .bwp__card-title { font-size: 12px; }
  .bwp__card-current { font-size: 13px; }
  .bwp__atc-btn { font-size: 11.5px; padding: 9px 10px; margin-top: 8px; }
  .bwp__card-badge { font-size: 8.5px; padding: 4px 7px; }
}

/* Shopify editor */
.shopify-design-mode .bwp__card { pointer-events: auto; }
</style>

{% schema %}
{
  "name": "Banner Products",
  "tag": "section",
  "class": "bwp-section",
  "settings": [
    {
      "type": "header",
      "content": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image",
      "info": "Recommended: at least 1600 × 800 px"
    },
    {
      "type": "select",
      "id": "banner_ratio",
      "label": "Banner height",
      "options": [
        { "value": "35",  "label": "Short (35%)"    },
        { "value": "45",  "label": "Medium (45%)"   },
        { "value": "55",  "label": "Tall (55%)"     },
        { "value": "65",  "label": "Extra tall (65%)" }
      ],
      "default": "55",
      "info": "Height as % of banner width."
    },
    {
      "type": "header",
      "content": "Banner Text"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "e.g. New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Our Latest Collection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our most-loved products, crafted with care."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Product Cards"
    },
    {
      "type": "checkbox",
      "id": "show_atc",
      "label": "Show Add to Cart button",
      "default": true
    },
    {
      "type": "text",
      "id": "atc_label",
      "label": "Add to Cart label",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "select_label",
      "label": "Select Options label",
      "default": "Select Options"
    },
    {
      "type": "text",
      "id": "sold_label",
      "label": "Sold Out label",
      "default": "Sold Out"
    },
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Warm Cream"    },
        { "value": "scheme-2", "label": "Pure White"    },
        { "value": "scheme-3", "label": "Soft Rose"     },
        { "value": "scheme-4", "label": "Dark Espresso" },
        { "value": "scheme-5", "label": "Midnight Black"}
      ],
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "placeholder": "e.g. 30% OFF",
          "info": "Leave blank to hide."
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Show star rating",
          "default": true
        },
        {
          "type": "range",
          "id": "star_count",
          "min": 0,
          "max": 5,
          "step": 1,
          "label": "Filled stars",
          "default": 5
        },
        {
          "type": "text",
          "id": "rating_text",
          "label": "Rating value",
          "default": "5.0",
          "placeholder": "e.g. 4.8"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Banner Products",
      "blocks": [
        { "type": "product", "settings": { "badge": "30% OFF", "show_rating": true, "star_count": 5, "rating_text": "5.0" } },
        { "type": "product", "settings": { "show_rating": true, "star_count": 5, "rating_text": "4.8" } },
        { "type": "product", "settings": { "badge": "New",     "show_rating": true, "star_count": 4, "rating_text": "4.5" } },
        { "type": "product", "settings": { "show_rating": true, "star_count": 5, "rating_text": "5.0" } }
      ]
    }
  ]
}
{% endschema %}
