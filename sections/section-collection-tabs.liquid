{% comment %}
  Collection Tabs Section — v4
  Place in: sections/collection-tabs.liquid
{% endcomment %}

{{ 'section-collection-tabs.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_heading = section.settings.heading | default: 'Customer Favourites'
  assign card_style = section.settings.card_style | default: 'card'
  assign show_badge = section.settings.show_badge
  assign badge_type = section.settings.badge_type | default: 'auto'
  assign badge_text = section.settings.badge_text | default: 'SALE'
  assign show_cart_btn = section.settings.show_cart_btn
  assign cart_btn_style = section.settings.cart_btn_style | default: 'icon'
  assign cart_icon_svg = section.settings.cart_icon_svg
  assign cart_btn_size = section.settings.cart_btn_size | default: 40
  assign cart_btn_radius = section.settings.cart_btn_radius | default: 50
  assign pt = section.settings.padding_top | default: 60
  assign pb = section.settings.padding_bottom | default: 60
-%}

<style>
  #shopify-section-{{ section.id }} .collection-tabs-section {
    --ct-badge-bg:        {{ section.settings.badge_bg_color | default: '#f5a88d' }};
    --ct-badge-text:      {{ section.settings.badge_text_color | default: '#ffffff' }};
    --ct-cart-bg:         {{ section.settings.cart_btn_bg | default: '#7b2d2d' }};
    --ct-cart-color:      {{ section.settings.cart_btn_color | default: '#ffffff' }};
    --ct-cart-size:       {{ cart_btn_size }}px;
    --ct-cart-radius:     {{ cart_btn_radius }}px;
      padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }
</style>

<div
  class="collection-tabs-section ct-style-{{ card_style }} color-{{ section.settings.color_scheme }} gradient"
  id="ct-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    {%- comment %} ── Header ── {%- endcomment %}
    <div class="collection-tabs__header">
      {%- if section_heading != blank -%}
        <h2 class="collection-tabs__heading {{ section.settings.heading_size }}">{{ section_heading }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="collection-tabs__buttons" role="tablist" aria-label="{{ section_heading }}">
          {%- for block in section.blocks -%}
            {%- assign tab_label = block.settings.tab_label -%}
            {%- if tab_label == blank -%}
              {%- assign _col = collections[block.settings.collection] -%}
              {%- assign tab_label = _col.title | default: 'Collection' -%}
            {%- endif -%}
            <button
              class="collection-tabs__tab-btn  button {% if forloop.first %}button--primary collection-tabs__tab-btn--active{% else %}button--secondary{% endif %}"
              data-tab-target="ct-tab-{{ section.id }}-{{ forloop.index }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="ct-tab-{{ section.id }}-{{ forloop.index }}"
              id="ct-btn-{{ section.id }}-{{ forloop.index }}"
              {{ block.shopify_attributes }}
            >
              {{- tab_label -}}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %} ── Panels ── {%- endcomment %}
    <div class="collection-tabs__panels">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- assign block_limit = block.settings.products_limit | default: 4 -%}
          {%- assign block_show_all = block.settings.show_view_all -%}
          {%- assign block_view_text = block.settings.view_all_text | default: 'View All' -%}
          {%- assign block_show_stars = block.settings.show_stars -%}
          {%- assign block_star_count = block.settings.star_count | default: 5 -%}
          {%- assign block_star_val = block.settings.star_value | default: '5.0' -%}
          {%- assign collection_selected = block.settings.collection -%}

          <div
            class="collection-tabs__panel{% if forloop.first %} collection-tabs__panel--active{% endif %}"
            id="ct-tab-{{ section.id }}-{{ forloop.index }}"
            role="tabpanel"
            aria-labelledby="ct-btn-{{ section.id }}-{{ forloop.index }}"
            tabindex="0"
          >
            {%- comment %}
              Show placeholders when:
              1. No collection is selected yet (collection_selected is blank), OR
              2. A collection is selected but has no products
              Show real products only when a collection is selected AND has products.
            {%- endcomment %}

            {%- if collection_selected == blank or col == blank or col.products_count == 0 -%}
              {%- comment %} ── Placeholder cards ── {%- endcomment %}
              <ul class="collection-tabs__grid  grid grid--2-col-tablet grid--4-col-desktop grid--1-col" role="list">
                {%- for i in (1..block_limit) -%}
                  <li class="grid__item color-{{ block.settings.color_scheme_2 }} gradient">
                    <div class="collection-tabs__card{% if card_style == 'card' %} collection-tabs__card--elevated{% endif %}">
                      <div class="collection-tabs__card-image-wrap">
                        {{
                          'product-'
                          | append: i
                          | placeholder_svg_tag: 'placeholder-svg collection-tabs__placeholder-img'
                        }}

                        {%- if show_cart_btn -%}
                          <button class="ct-cart-btn ct-cart-btn--corner" aria-label="Add to cart" disabled>
                            {%- if cart_icon_svg != blank -%}
                              {{ cart_icon_svg }}
                            {%- elsif cart_btn_style != 'text_only' -%}
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                width="18"
                                height="18"
                              >
                                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                              </svg>
                            {%- endif -%}
                            {%- if cart_btn_style == 'text' or cart_btn_style == 'text_only' -%}
                              <span>Add to Cart</span>
                            {%- endif -%}
                          </button>
                        {%- endif -%}
                      </div>

                      <div class="collection-tabs__card-info">
                        {%- if block_show_stars -%}
                          <div class="collection-tabs__card-stars" aria-hidden="true">★★★★★ <span>5.0</span></div>
                        {%- endif -%}
                        <p class="collection-tabs__card-title">Sample Product {{ i }}</p>
                        <p class="collection-tabs__card-price">$0.00</p>
                      </div>
                    </div>
                  </li>
                {%- endfor -%}
              </ul>

            {%- else -%}
              {%- comment %} ── Real product cards ── {%- endcomment %}
              <ul class="collection-tabs__grid grid grid--2-col-tablet grid--4-col-desktop grid--1-col" role="list">
                {%- for product in col.products limit: block_limit -%}
                  <li class="grid__item color-{{ block.settings.color_scheme_2 }} gradient">
                    {%- render 'collection-tabs-card',
                      product: product,
                      show_stars: block_show_stars,
                      star_count: block_star_count,
                      star_value: block_star_val,
                      show_badge: show_badge,
                      badge_type: badge_type,
                      badge_text: badge_text,
                      card_style: card_style,
                      show_cart_btn: show_cart_btn,
                      cart_btn_style: cart_btn_style,
                      cart_icon_svg: cart_icon_svg
                    -%}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if block_show_all and col.products_count > block_limit -%}
                <div class="collection-tabs__view-all">
                  <a href="{{ col.url }}" class="collection-tabs__view-all-link link underlined-link">
                    {{ block_view_text }}
                  </a>
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endfor -%}

      {%- else -%}
        {%- comment %} ── No blocks added yet: show editor hint ── {%- endcomment %}
        {%- if request.design_mode -%}
          <div class="collection-tabs__empty collection-tabs__empty--no-blocks">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              opacity="0.3"
            >
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <p>Add a Collection Tab block to get started.</p>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

<script>
      (function () {
        'use strict';

        function CollectionTabs(sectionEl) {
          this.el = sectionEl;
          this.buttons = Array.from(sectionEl.querySelectorAll('.collection-tabs__tab-btn'));
          this.panels = Array.from(sectionEl.querySelectorAll('.collection-tabs__panel'));
          this._bindEvents();
        }

        CollectionTabs.prototype._bindEvents = function () {
          var self = this;
          this.buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
              self._switchTab(btn);
            });
            btn.addEventListener('keydown', function (e) {
              if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
                var dir = e.key === 'ArrowRight' ? 1 : -1;
                var idx = self.buttons.indexOf(btn);
                var next = self.buttons[(idx + dir + self.buttons.length) % self.buttons.length];
                if (next) {
                  next.focus();
                  self._switchTab(next);
                }
              }
            });
          });
        };

        {% comment %} CollectionTabs.prototype._switchTab = function (activeBtn) {
          var targetId = activeBtn.dataset.tabTarget;
          this.buttons.forEach(function (b) {
            var active = b === activeBtn;
            b.classList.toggle('collection-tabs__tab-btn--active', active);
            b.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          this.panels.forEach(function (p) {
            p.classList.toggle('collection-tabs__panel--active', p.id === targetId);
          });
        }; {% endcomment %}

        CollectionTabs.prototype._switchTab = function (activeBtn) {
    var targetId = activeBtn.dataset.tabTarget;

    this.buttons.forEach(function (b) {
      var active = b === activeBtn;

      b.classList.toggle('collection-tabs__tab-btn--active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');

      if (active) {
        b.classList.add('button--primary');
        b.classList.remove('button--secondary');
      } else {
        b.classList.add('button--secondary');
        b.classList.remove('button--primary');
      }
    });

    this.panels.forEach(function (p) {
      p.classList.toggle('collection-tabs__panel--active', p.id === targetId);
    });
  };

        function init() {
          document.querySelectorAll('.collection-tabs-section').forEach(function (el) {
            new CollectionTabs(el);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
</script>

{% schema %}
{
  "name": "Collection Tabs",
  "tag": "section",
  "class": "section-collection-tabs",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Customer Favourites"
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "standard", "label": "Standard — flat, blends with section background" },
        { "value": "card", "label": "Card — elevated with distinct card background" }
      ],
      "default": "card",
      "info": "Standard: products share section background color. Card: each product has its own card color with shadow."
    },
    {
      "type": "header",
      "content": "Badge Settings"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Sale Badge",
      "default": true,
      "info": "Badge appears only when a product's compare-at price is higher than its sale price."
    },
    {
      "type": "select",
      "id": "badge_type",
      "label": "Badge Display Type",
      "options": [
        { "value": "auto", "label": "Auto — show % discount (e.g. 30% OFF)" },
        { "value": "custom", "label": "Custom — show your own text on sale items" }
      ],
      "default": "auto"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Custom Badge Text",
      "default": "SALE",
      "info": "Only used when Badge Type is set to Custom"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#f5a88d"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Cart Button"
    },
    {
      "type": "checkbox",
      "id": "show_cart_btn",
      "label": "Show Cart Button on Hover",
      "default": true,
      "info": "Button appears at the bottom-right corner of the product image on hover."
    },
    {
      "type": "select",
      "id": "cart_btn_style",
      "label": "Cart Button Style",
      "options": [
        { "value": "icon", "label": "Icon Only" },
        { "value": "text", "label": "Icon + Add to Cart Text" },
        { "value": "text_only", "label": "Text Only" }
      ],
      "default": "icon"
    },
    {
      "type": "html",
      "id": "cart_icon_svg",
      "label": "Custom Cart Icon SVG",
      "info": "Paste custom SVG here. Leave blank to use the default cart icon."
    },
    {
      "type": "color",
      "id": "cart_btn_bg",
      "label": "Cart Button Background Color",
      "default": "#7b2d2d"
    },
    {
      "type": "color",
      "id": "cart_btn_color",
      "label": "Cart Button Icon / Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "cart_btn_size",
      "label": "Cart Button Size (px)",
      "min": 32,
      "max": 64,
      "step": 2,
      "default": 40,
      "info": "Controls the width and height of the cart button."
    },
    {
      "type": "range",
      "id": "cart_btn_radius",
      "label": "Cart Button Border Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50,
      "info": "50 = fully round circle. 0 = square."
    },
    {
      "type": "header",
      "content": "Colors — Section"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background Color",
      "default": "#fdf6f2"
    },
    {
      "type": "header",
      "content": "Colors — Cards"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background Color",
      "default": "#ffffff",
      "info": "Only visible when Card Style is set to Card"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#2a1a1a"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Rating Color",
      "default": "#e8943a"
    },
    {
      "type": "header",
      "content": "Colors — Tab Buttons"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Active Tab Background",
      "default": "#7b2d2d"
    },
    {
      "type": "color",
      "id": "tab_active_text",
      "label": "Active Tab Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "Inactive Tab Border Color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "header",
          "content": "Collection"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "inline_richtext",
          "id": "tab_label",
          "label": "Custom Tab Label",
          "info": "Leave blank to use the collection title automatically"
        },
 {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1"
    },
        {
          "type": "color_scheme",
          "id": "color_scheme_2",
          "label": "t:sections.all.colors.label",
          "info": "t:sections.all.colors.has_cards_info"
        },
        {
          "type": "header",
          "content": "Products"
        },
        {
          "type": "range",
          "id": "products_limit",
          "label": "Max Products to Show",
          "min": 2,
          "max": 8,
          "step": 1,
          "default": 4,
          "info": "Controls how many products are shown in this tab"
        },
        {
          "type": "header",
          "content": "View All"
        },
        {
          "type": "checkbox",
          "id": "show_view_all",
          "label": "Show View All Link",
          "default": true,
          "info": "Link only appears if the collection has more products than the limit above"
        },
        {
          "type": "text",
          "id": "view_all_text",
          "label": "View All Link Text",
          "default": "View All"
        },
        {
          "type": "header",
          "content": "Star Ratings"
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show Star Ratings",
          "default": true
        },
        {
          "type": "range",
          "id": "star_count",
          "label": "Number of Stars (filled)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "info": "Static star display — same for all products in this tab"
        },
        {
          "type": "select",
          "id": "star_value",
          "label": "Rating Value Display",
          "options": [
            { "value": "5.0", "label": "5.0" },
            { "value": "4.9", "label": "4.9" },
            { "value": "4.8", "label": "4.8" },
            { "value": "4.7", "label": "4.7" },
            { "value": "4.5", "label": "4.5" },
            { "value": "4.0", "label": "4.0" }
          ],
          "default": "5.0"
        }
      ]
    }
  ],
 "presets": [
  {
    "name": "Collection Tabs",
    "blocks": [
      {
        "type": "collection_tab"
      }
    ]
  }
]
}
{% endschema %}
