  <script>
        (function () {
          'use strict';


      if (window.innerWidth < 990) return;
          const header = document.getElementById('site-header');
          if (!header) return;
          const sectionHeader = header.closest('.section-header');
          if (!sectionHeader) return;

          /* ── Settings from Liquid ── */
          const enableTransparent = {{ section.settings.enable_transparent_header | json }};
          const enableLogoHide    = {{ section.settings.enable_scroll_logo_hide | json }};

          /* ── Constants ── */
          const SCROLL_THRESHOLD = 60;  /* px — before pill/scroll state activates */
          const DIR_THRESHOLD    = 10;  /* px — minimum delta to detect direction   */

          let lastScrollY = window.pageYOffset || window.scrollY;
          let rafTicking  = false;

          function onScroll() {
            const scrollY = window.pageYOffset || window.scrollY;
            const delta   = scrollY - lastScrollY;  /* +ve = scrolling down, -ve = up */

            /* ── 1. Back at top → reset all states ── */
            if (scrollY <= SCROLL_THRESHOLD) {
              sectionHeader.classList.remove('scrolled-past-header');
              header.classList.remove('header--pill-hidden');
              if (enableLogoHide) header.classList.remove('logo-is-hidden');
              lastScrollY = scrollY;
              return;
            }

            /* ── 2. Scrolling DOWN ── */
            if (delta > DIR_THRESHOLD) {
              if (enableTransparent) {
                sectionHeader.classList.add('scrolled-past-header');
                header.classList.remove('header--pill-hidden');
              }
              /* Logo hide works regardless of transparent setting */
              if (enableLogoHide) header.classList.add('logo-is-hidden');
            }

            /* ── 3. Scrolling UP ── */
            if (delta < -DIR_THRESHOLD) {
              if (enableTransparent) header.classList.add('header--pill-hidden');
              /* Show logo again on scroll up */
              if (enableLogoHide) header.classList.remove('logo-is-hidden');
            }

            lastScrollY = scrollY;
          }

          /* rAF throttle — 60fps smooth */
          window.addEventListener('scroll', function () {
            if (!rafTicking) {
              window.requestAnimationFrame(function () {
                onScroll();
                rafTicking = false;
              });
              rafTicking = true;
            }






          }, { passive: true });

          /* Run once on load */
          onScroll();

          /* ── SVG Icon Color Fix ──
             Remove hardcoded fill/stroke attributes from custom SVGs
             so CSS variables take full control of icon colors.
          ── */
          function cleanSvgAttrs(svgEl) {
            if (!svgEl) return;
            ['fill','stroke','color'].forEach(function(a) {
              svgEl.removeAttribute(a);
              svgEl.style.removeProperty(a);
            });
            svgEl.querySelectorAll('*').forEach(function (el) {
              var fill   = el.getAttribute('fill');
              var stroke = el.getAttribute('stroke');
              if (fill   && fill   !== 'none') el.removeAttribute('fill');
              if (stroke && stroke !== 'none') el.removeAttribute('stroke');
              el.style.removeProperty('fill');
              el.style.removeProperty('stroke');
            });
          }

          function applyIconFix() {
            document.querySelectorAll(
              '.custom-search-icon svg, .custom-cart-icon svg, .custom-account-icon svg'
            ).forEach(cleanSvgAttrs);
          }

          applyIconFix();
          document.addEventListener('shopify:section:load', applyIconFix);

            window.addEventListener('resize', () => {

    if(window.innerWidth < 990){

    const sectionHeader = document.querySelector('.section-header')
    const header = document.getElementById('site-header')

    sectionHeader?.classList.remove('scrolled-past-header')
    header?.classList.remove('header--pill-hidden','logo-is-hidden')

    }

    })
        })();
  </script>

